export void g_HIL_Clib_Swc_Clib_WakeUp()
{
  g_HIL_Bus_Swc_Enable_CAN("ICAN"); //测试步骤 Enable_CAN ICAN
  g_HIL_Bus_Swc_Enable_CAN("ECAN"); //测试步骤 Enable_CAN ECAN
