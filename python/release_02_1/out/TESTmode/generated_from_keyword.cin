  g_HIL_Bus_Swc_Enable_CAN("LLIN2"); //测试步骤 Enable_CAN LLIN2
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch35::DigitalOutput 0"); //测试步骤 Set J_DI_FLOutHandle_LS notpulled
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch35::DigitalOutput 1"); //测试步骤 Set J_DI_FLOutHandle_LS pulled
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch35::DigitalOutput 0"); //测试步骤 Set J_DI_FLOutHandle_LS notpulled
}

