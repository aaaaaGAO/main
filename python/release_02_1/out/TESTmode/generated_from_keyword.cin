export void g_HIL_Clib_Swc_Clib_CDCULock()
{
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0"); //测试步骤 Set J_DI_FLDoorAjarSW_LS Close
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch31::DigitalOutput 0"); //测试步骤 Set J_DI_RLDoorAjarSW_LS Close
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0"); //测试步骤 Set I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_RRDoorAjarSt 0"); //测试步骤 Set I_RDCU_BodySysSt1::I_RDCU_RRDoorAjarSt 0
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_BonnetAjarSt 0"); //测试步骤 Set I_RDCU_BodySysSt1::I_RDCU_BonnetAjarSt 0
  g_HIL_XCP_Swc_Set_XCP("CalEn_Debug_TrnkCurHallPos 1"); //测试步骤 Set_XCP CalEn_Debug_TrnkCurHallPos 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_Debug_TrnkCurHallPos 0"); //测试步骤 Set_XCP CalVal_Debug_TrnkCurHallPos 0//小于120
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch30::DigitalOutput 0"); //测试步骤 Set J_DI_RDoorlockPawlSw_LS INACTIVE
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch29::DigitalOutput 0"); //测试步骤 Set J_DI_RDoorlockSecondSw_LS INACTIVE//全锁
  g_HIL_Bus_Swc_Set("VTS::VT2848_2_Ch35::DigitalOutput 0"); //测试步骤 Set J_DI_RDoorlockResetSw_LS INACTIVE
  g_HIL_Gen_Swc_Wait("400 ms"); //测试步骤 Wait 400 ms
  g_HIL_Bus_Swc_Set("VTS::VT2516_1_Ch4::DigitalOutput 1"); //测试步骤 Set J_AI_DrvSeatSBRSt Unoccupied
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_LDCU_CentralLockSw 0"); //测试步骤 Set I_CDCU_LDCU_BodyCtrl::I_CDCU_LDCU_CentralLockSw 0//No command
  g_HIL_Gen_Swc_Wait("501 ms"); //测试步骤 Wait 501 ms//
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_LDCU_CentralLockSw 1"); //测试步骤 Set I_CDCU_LDCU_BodyCtrl::I_CDCU_LDCU_CentralLockSw 1//大屏闭锁0x1:Door lock
  g_HIL_Gen_Swc_Wait("301 ms"); //测试步骤 Wait 301 ms//
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_LDCU_CentralLockSw 0"); //测试步骤 Set I_CDCU_LDCU_BodyCtrl::I_CDCU_LDCU_CentralLockSw 0//No command
  g_HIL_Gen_Swc_Wait("301 ms"); //测试步骤 Wait 301 ms//
}

