export void g_HIL_Clib_Swc_Clib_EPBTestSetup()
{
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 1"); //测试步骤 Set J_KL30 ON//打开右域的J_KL30
  g_HIL_Bus_Swc_Set("C_XPU_IPB_ADASToqCtrl::C_XPU_AD_EPBReqVD 1"); //测试步骤 Set C_XPU_IPB_ADASToqCtrl::C_XPU_AD_EPBReqVD 1
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfo_E2E::C_IPB_FLWheelSpdVD_E2E 1"); //测试步骤 Set C_IPB_SpdInfo_E2E::C_IPB_FLWheelSpdVD_E2E 1
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfo_E2E::C_IPB_FRWheelSpdVD_E2E 1"); //测试步骤 Set C_IPB_SpdInfo_E2E::C_IPB_FRWheelSpdVD_E2E 1
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfo_E2E::C_IPB_RLWheelSpdVD_E2E 1"); //测试步骤 Set C_IPB_SpdInfo_E2E::C_IPB_RLWheelSpdVD_E2E 1
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfo_E2E::C_IPB_RRWheelSpdVD_E2E 1"); //测试步骤 Set C_IPB_SpdInfo_E2E::C_IPB_RRWheelSpdVD_E2E 1
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfo_E2E::C_IPB_VehSpdVD_E2E 1"); //测试步骤 Set C_IPB_SpdInfo_E2E::C_IPB_VehSpdVD_E2E 1
}

export void g_HIL_Clib_Swc_Clib_EPBTestCleanup()
{
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 0"); //测试步骤 Set J_KL30 OFF//关闭右域的J_KL30，让右域停发报文，以免影响其他测试
  g_HIL_Clib_Swc_Clib_EnableRDCUMsg(); //测试步骤 Clib EnableRDCUMsg
}

export void g_HIL_Clib_Swc_Clib_Clean_DTC()
{
  g_HIL_UDS_Swc_Set_UDS("14 FF FF FF"); //测试步骤 Set_UDS 14 FF FF FF
  g_HIL_Gen_Swc_Wait("5000 ms"); //测试步骤 Wait 5000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 0"); //测试步骤 Set J_KL30 OFF
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 1"); //测试步骤 Set J_KL30 ON
  g_HIL_Gen_Swc_Wait("1000 ms"); //测试步骤 Wait 1000 ms
}
