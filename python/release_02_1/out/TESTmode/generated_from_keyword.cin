export void g_HIL_Clib_Swc_Clib_Init()
{
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 0"); //测试步骤 Set J_KL30 OFF
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 1"); //测试步骤 Set J_KL30 ON
  g_HIL_Gen_Swc_Wait("1000 ms"); //测试步骤 Wait 1000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 13"); //测试步骤 Set J_BAT 13
  g_HIL_Bus_Swc_Set("SYS::IT6512D::CurrentSet 40"); //测试步骤 Set J_BAT_CURR_SV 40
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Gen_Swc_Wait("500 ms"); //测试步骤 Wait 500 ms
  g_HIL_UDS_Swc_Set_UDS("SA_L1"); //测试步骤 Set_UDS SA_L1
  g_HIL_Gen_Swc_Wait("301 ms"); //测试步骤 Wait 301 ms
  g_HIL_Gen_Swc_Wait("1000 ms"); //测试步骤 Wait 1000 ms
  g_HIL_Bus_Swc_Disable_CAN("ICAN"); //测试步骤 Disable_CAN ICAN
  g_HIL_Bus_Swc_Disable_CAN("ECAN"); //测试步骤 Disable_CAN ECAN
  g_HIL_Bus_Swc_Disable_CAN("CCAN"); //测试步骤 Disable_CAN CCAN
  g_HIL_Bus_Swc_Disable_CAN("BLCAN"); //测试步骤 Disable_CAN BLCAN
  g_HIL_Bus_Swc_Disable_CAN("LLIN2"); //测试步骤 Disable_CAN LLIN2
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Enable_CAN("ICAN"); //测试步骤 Enable_CAN ICAN
  g_HIL_Bus_Swc_Enable_CAN("ECAN"); //测试步骤 Enable_CAN ECAN
  g_HIL_Bus_Swc_Enable_CAN("CCAN"); //测试步骤 Enable_CAN CCAN
  g_HIL_Bus_Swc_Enable_CAN("BLCAN"); //测试步骤 Enable_CAN BLCAN
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_XCP_Swc_Set_XCP("CalEn_FIN_BrkPedalStVD 1"); //测试步骤 Set_XCP CalEn_FIN_BrkPedalStVD 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_FIN_BrkPedalStVD 1"); //测试步骤 Set_XCP CalVal_FIN_BrkPedalStVD 1
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt4::I_RDCU_PsngrHandleSt 1"); //测试步骤 Set I_RDCU_BodySysSt4::I_RDCU_PsngrHandleSt 1
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt4::I_RDCU_RRHandleSt 1"); //测试步骤 Set I_RDCU_BodySysSt4::I_RDCU_RRHandleSt 1
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt4::I_RDCU_RFHandlePos 0"); //测试步骤 Set I_RDCU_BodySysSt4::I_RDCU_RFHandlePos 0
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt4::I_RDCU_RRHandlePos 0"); //测试步骤 Set I_RDCU_BodySysSt4::I_RDCU_RRHandlePos 0
  g_HIL_Gen_Swc_Wait("301 ms"); //测试步骤 Wait 301 ms
  g_HIL_UDS_Swc_Set_Config("PhysicalKeyTypeConfig 0x02"); //测试步骤 Step Set_Config PhysicalKeyTypeConfig BLEPhysicalKeyOnly//数字钥匙
  // Step Set_Config PhysicalKeyTypeConfig open // 测试步骤DID Configuration 表中 name PhysicalKeyTypeConfig 的Values 未匹配: open
  teststep("step","Step Set_Config PhysicalKeyTypeConfig open");
  teststepfail("fail","DID Configuration 表中 name PhysicalKeyTypeConfig 的Values 未匹配: open");
  g_HIL_UDS_Swc_Set_Config("PhysicalKeyTypeConfig 123"); //测试步骤 Step Set_Config PhysicalKeyTypeConfig 123//数字钥匙
  // Step Set_Config abc 123 // 测试步骤DID Configuration 表中Name 未找到: abc
  teststep("step","Step Set_Config abc 123");
  teststepfail("fail","DID Configuration 表中Name 未找到: abc");
  g_HIL_Bus_Swc_Set("VTS::VT2516_5_Ch4::PWMDC > 0.95 0"); //测试步骤 Step Set J_PO_LS_LDoorHandleLight_Duty OFF 0
}

export void g_HIL_Clib_Swc_Clib_Initial()
{
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 13"); //测试步骤 Set J_BAT 13
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 1"); //测试步骤 Set J_KL30 ON
  g_HIL_UDS_Swc_Set_UDS("SA_L1"); //测试步骤 Set_UDS SA_L1
}

export void g_HIL_Clib_Swc_Clib_BATOFF()
{
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 0"); //测试步骤 Set J_KL30 OFF
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
}

export void g_HIL_Clib_Swc_Clib_BATON()
{
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 1"); //测试步骤 Set J_KL30 ON
  g_HIL_Gen_Swc_Wait("1000 ms"); //测试步骤 Wait 1000 ms
}

export void g_HIL_Clib_Swc_Clib_Reset()
{
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 0"); //测试步骤 Set J_KL30 OFF
  g_HIL_Gen_Swc_Wait("2000 ms"); //测试步骤 Wait 2000 ms
  g_HIL_Bus_Swc_Set("VTS::VT7101_1_Out1::Active 1"); //测试步骤 Set J_KL30 ON
  g_HIL_Gen_Swc_Wait("500 ms"); //测试步骤 Wait 500 ms
}

export void g_HIL_Clib_Swc_Clib_OFF()
{
  g_HIL_Bus_Swc_Set("C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0"); //测试步骤 Set C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0
  g_HIL_XCP_Swc_Set_XCP("CalEn_Vcu_MO_Motor_laeuft 1"); //测试步骤 Set_XCP CalEn_Vcu_MO_Motor_laeuft 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_Vcu_MO_Motor_laeuft 0"); //测试步骤 Set_XCP CalVal_Vcu_MO_Motor_laeuft 0
  g_HIL_XCP_Swc_Set_XCP("CalEn_KeyValidSt 80"); //测试步骤 Set_XCP CalEn_KeyValidSt 80
  g_HIL_XCP_Swc_Set_XCP("CalVal_KeyValidSt 1"); //测试步骤 Set_XCP CalVal_KeyValidSt 1
  g_HIL_XCP_Swc_Set_XCP("CalEn_FIN_CurGearLev 1"); //测试步骤 Set_XCP CalEn_FIN_CurGearLev 1
  g_HIL_XCP_Swc_Set_XCP("CalEn_FIN_GearLev 4"); //测试步骤 Set_XCP CalEn_FIN_GearLev 4
  g_HIL_XCP_Swc_Set_XCP("CalVal_FIN_CurGearLev 4"); //测试步骤 Set_XCP CalVal_FIN_CurGearLev 4
  g_HIL_XCP_Swc_Set_XCP("CalVal_FIN_GearLev 4"); //测试步骤 Set_XCP CalVal_FIN_GearLev 4
  g_HIL_XCP_Swc_Set_XCP("CalC_GearLev_Valid 1"); //测试步骤 Set_XCP CalC_GearLev_Valid 1
  g_HIL_XCP_Swc_Set_XCP("CalC_GearLev_Val 5"); //测试步骤 Set_XCP CalC_GearLev_Val 5
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 0"); //测试步骤 Set J_DI_BrakeSw1_HS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 0"); //测试步骤 Set J_DI_BrakeSw2_HS NotPressed
  g_HIL_Gen_Swc_Wait("400 ms"); //测试步骤 Wait 400 ms
  g_HIL_Bus_Swc_Condition_ReadConfig("DoorAjarSwType"); //测试步骤 Step Condition_ReadConfig DoorAjarSwType
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0x00 0;0x01 1"); //测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0x00 close;0x01 open
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0x00 1;0x01 0"); //测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0x00 open;0x01 close
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0x00 0;0x01 1"); //测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0x00 close;0x01 open
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 0"); //测试步骤 Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch23::DigitalOutput 0"); //测试步骤 Set J_DI_KL15_BackUp_HS INACTIVE
}

export void g_HIL_Clib_Swc_Clib_ForceOFF()
{
  g_HIL_XCP_Swc_Set_XCP("CalEn_KeyValidSt 80"); //测试步骤 Set_XCP CalEn_KeyValidSt 80
  g_HIL_XCP_Swc_Set_XCP("CalVal_KeyValidSt 1"); //测试步骤 Set_XCP CalVal_KeyValidSt 1
  g_HIL_XCP_Swc_Set_XCP("CalEn_FIN_CurGearLev 1"); //测试步骤 Set_XCP CalEn_FIN_CurGearLev 1
  g_HIL_XCP_Swc_Set_XCP("CalEn_FIN_GearLev 1"); //测试步骤 Set_XCP CalEn_FIN_GearLev 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_FIN_CurGearLev 4"); //测试步骤 Set_XCP CalVal_FIN_CurGearLev 4
  g_HIL_XCP_Swc_Set_XCP("CalVal_FIN_GearLev 4"); //测试步骤 Set_XCP CalVal_FIN_GearLev 4
  g_HIL_Bus_Swc_Condition_ReadConfig("DoorAjarSwType"); //测试步骤 Step Condition_ReadConfig DoorAjarSwType
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0x00 0;0x01 1"); //测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0x00 close;0x01 open
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0x00 1;0x01 0"); //测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0x00 open;0x01 close
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0x00 0;0x01 1"); //测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0x00 close;0x01 open
  g_HIL_Gen_Swc_Wait("300 ms"); //测试步骤 Wait 300 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 1"); //测试步骤 Set J_DI_SSBPin4SW_LS Pressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 1"); //测试步骤 Set J_DI_SSBPin6SW_LS Pressed
  g_HIL_Gen_Swc_Wait("5500 ms"); //测试步骤 Wait 5500 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 0"); //测试步骤 Set J_DI_SSBPin4SW_LS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 0"); //测试步骤 Set J_DI_SSBPin6SW_LS NotPressed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 0"); //测试步骤 Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 0
}

