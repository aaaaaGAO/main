export void g_HIL_Clib_Swc_Clib_TrunkMaxPosLearned()
{
  g_HIL_Clib_Swc_Clib_Reset(); //测试步骤 Clib Reset
  g_HIL_XCP_Swc_Set_XCP("CalC_TrnkLvrMtrStlTm_msec 3000"); //测试步骤 Set_XCP CalC_TrnkLvrMtrStlTm_msec 3000//堵转阈值
  g_HIL_XCP_Swc_Set_XCP("CalC_TrnkHallSnsrLostDetTm_ms 4000"); //测试步骤 Set_XCP CalC_TrnkHallSnsrLostDetTm_ms 4000//hall故障阈值
  g_HIL_XCP_Swc_Set_XCP("CalEn_Debug_TrnkCurHallPos 1"); //测试步骤 Set_XCP CalEn_Debug_TrnkCurHallPos 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_Debug_TrnkCurHallPos 2160"); //测试步骤 Set_XCP CalVal_Debug_TrnkCurHallPos 2160//大于2350
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch19::DigitalOutput 0"); //测试步骤 Set J_DI_TrunkOpenSw_LS INACTIVE
  g_HIL_Gen_Swc_Wait("301 ms"); //测试步骤 Wait 301 ms
  g_HIL_Clib_Swc_Clib_TrnkFullOpened(); //测试步骤 Clib TrnkFullOpened
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfoF::C_IPB_VehSpd 0"); //测试步骤 Set C_IPB_SpdInfoF::C_IPB_VehSpd 0
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfoF::C_IPB_VehSpdVD 1"); //测试步骤 Set C_IPB_SpdInfoF::C_IPB_VehSpdVD 1
  g_HIL_Clib_Swc_Clib_Unlock(); //测试步骤 Clib Unlock
  g_HIL_XCP_Swc_Set_XCP("CalEn_Debug_TrnkCurHallPos 1"); //测试步骤 Set_XCP CalEn_Debug_TrnkCurHallPos 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_Debug_TrnkCurHallPos 0"); //测试步骤 Set_XCP CalVal_Debug_TrnkCurHallPos 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch19::DigitalOutput 1"); //测试步骤 Set J_DI_TrunkOpenSw_LS ACTIVE//触发关门
  g_HIL_Gen_Swc_Wait("150 ms"); //测试步骤 Wait 150 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch19::DigitalOutput 0"); //测试步骤 Set J_DI_TrunkOpenSw_LS INACTIVE
  g_HIL_Gen_Swc_Wait("150 ms"); //测试步骤 Wait 150 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch30::DigitalOutput 0"); //测试步骤 Set J_DI_RDoorlockPawlSw_LS INACTIVE
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch29::DigitalOutput 0"); //测试步骤 Set J_DI_RDoorlockSecondSw_LS INACTIVE//全锁
  g_HIL_Gen_Swc_Wait("3000 ms"); //测试步骤 Wait 3000 ms
  g_HIL_Bus_Swc_Check("I_LDCU_TgateSysSts::I_TgateInitSt 1"); //测试步骤 Check I_LDCU_TgateSysSts::I_TgateInitSt 1//ZeroPos Learned
  g_HIL_Clib_Swc_Clib_TrnkOpened(); //测试步骤 Clib TrnkOpened
  g_HIL_Gen_Swc_Wait("301 ms"); //测试步骤 Wait 301 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch19::DigitalOutput 1"); //测试步骤 Set J_DI_TrunkOpenSw_LS ACTIVE//开尾门
  g_HIL_Gen_Swc_Wait("150 ms"); //测试步骤 Wait 150 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch19::DigitalOutput 0"); //测试步骤 Set J_DI_TrunkOpenSw_LS INACTIVE
  g_HIL_Gen_Swc_Wait("150 ms"); //测试步骤 Wait 150 ms
  g_HIL_XCP_Swc_Set_XCP("CalEn_Debug_TrnkCurHallPos 1"); //测试步骤 Set_XCP CalEn_Debug_TrnkCurHallPos 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_Debug_TrnkCurHallPos 2160"); //测试步骤 Set_XCP CalVal_Debug_TrnkCurHallPos 2160//2260正负80为可上止点学习区间
  g_HIL_Gen_Swc_Wait("3000 ms"); //测试步骤 Wait 3000 ms//等待堵转
  g_HIL_Bus_Swc_Check("I_LDCU_TgateSysSts::I_TgateInitSt 2"); //测试步骤 Check I_LDCU_TgateSysSts::I_TgateInitSt 2//MaxPos Learned
}

