  g_HIL_Bus_Swc_Check("I_LDCU_VheicleLevelingAngle::I_VheicleLevelingSt_PWMVD 1"); // 预期结果 Step Check I_LDCU_VheicleLevelingAngle::I_VheicleLevelingSt_PWMVD 1//0:Not Initialized;2:Invalid；
  g_HIL_Bus_Swc_Set("VTS::VT2516_3_Ch1::DigitalOutput 0.75"); // 测试步骤 Step Set J_PI_VehicleHeightSensorFb 0.75
  g_HIL_Gen_Swc_Wait("5 s"); // 测试步骤 Step Wait 5 s
  g_HIL_Bus_Swc_Check("I_LDCU_VheicleLevelingAngle::I_VehicleLevelingSt_PWM >= 1350 and <= 1450"); // 预期结果 Step Check I_LDCU_VheicleLevelingAngle::I_VehicleLevelingSt_PWM >= 1350 and <= 1450
  g_HIL_Bus_Swc_Check("I_LDCU_VheicleLevelingAngle::I_VheicleLevelingSt_PWMVD 1"); // 预期结果 Step Check I_LDCU_VheicleLevelingAngle::I_VheicleLevelingSt_PWMVD 1//0:Not Initialized;2:Invalid；
  g_HIL_Bus_Swc_Set("VTS::VT2516_3_Ch1::DigitalOutput 0.875"); // 测试步骤 Step Set J_PI_VehicleHeightSensorFb 0.875 //实际高于0.866时，进入invaild,同时角度止步于1650
  g_HIL_Gen_Swc_Wait("5 s"); // 测试步骤 Step Wait 5 s
  g_HIL_Bus_Swc_Check("I_LDCU_VheicleLevelingAngle::I_VehicleLevelingSt_PWM >= 1550 and <= 1650"); // 预期结果 Step Check I_LDCU_VheicleLevelingAngle::I_VehicleLevelingSt_PWM >= 1550 and <= 1650
