  g_HIL_Gen_Swc_Wait("5 s"); // 测试步骤 Step Wait 5 s
  g_HIL_Bus_Swc_Check("I_LDCU_VheicleLevelingAngle::I_VehicleLevelingSt_PWM >= 950 and <= 1050"); // 预期结果 Step Check I_LDCU_VheicleLevelingAngle::I_VehicleLevelingSt_PWM >= 950 and <= 1050
