testcase SYS_CDCU_wendudiaojieIGON_0001()
{
  TestDescription("主驾空调温度调节 Power=ON");
  teststep("warning","原始用例id为SYS-CDCU-温度调节IGON-0001");
  g_EM_Equipment_Swc_TC_PW("ON"); // 测试步骤 TC_PW ON
  g_EM_Equipment_Swc_TC_IG("ON"); // 测试步骤 TC_IG ON
  g_CAN_Bus_Swc_Set("C_LDCU_SysSt.C_LDCU_EVSysReadySt 2"); // 测试步骤 TC_CANTest SET C_LDCU_SysSt.C_LDCU_EVSysReadySt 2//上高压
  g_CAN_Bus_Swc_Set("I_LDCU_BodySysSt1.I_LDCU_PowerMode 1"); // 测试步骤 TC_CANTest SET I_LDCU_BodySysSt1.I_LDCU_PowerMode 1
  gTC_CANTest_SOA_Set8001Delay("0"); // 测试步骤 TC_CANTest SOA Set8001Delay 0
  gTC_CANTest_SOA_SetSever("TempSelectStStruct.DriverTempSelectSt:20"); // 测试步骤 TC_CANTest SOA SetServer TempSelectStStruct.DriverTempSelectSt:20//
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("2"); // 测试步骤 TC_Sleep 2
  g_EM_SOAClient_Swc_SOA_SubPeriod("SOAEngineInterState 1"); // 测试步骤 TC_CANTest SOA SubPeriod SOAEngineInterState 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("Veh_HVACService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod Veh_HVACService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("Veh_HVACPush 1"); // 测试步骤 TC_CANTest SOA SubPeriod Veh_HVACPush 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_DriverTempUpRespStruct.Veh_DriverTempUpNRC 0"); // 预期结果 TC_CANTest SOA check Veh_DriverTempUpRespStruct.Veh_DriverTempUpNRC 0
  gTC_CANTest_SOA_CheckReq_Prepare("SetDrvTempStruct.SetDrvTemp 20.5&MemoryReq 0&Type 0"); // 预期结果 TC_CANTest SOA CheckReq SetDrvTempStruct.SetDrvTemp 20.5&MemoryReq 0&Type 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1"); // 预期结果 TC_CANTest SOA check Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1 //检查RESPONSE
  g_EM_SOAClient_Swc_SOA_REQ("Veh_DriverTempUpStruct.Veh_DriverTempUp:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ Veh_DriverTempUpStruct.Veh_DriverTempUp:1&ServiceExecuteFeedbackFlag:2 //0.5步进
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_DriverTempUpRespStruct.Veh_DriverTempUpNRC 0"); // 预期结果 TC_CANTest SOA check Veh_DriverTempUpRespStruct.Veh_DriverTempUpNRC 0
  gTC_CANTest_SOA_CheckReq("SetDrvTempStruct.SetDrvTemp 20.5&MemoryReq 0&Type 0"); // 预期结果 TC_CANTest SOA CheckReq SetDrvTempStruct.SetDrvTemp 20.5&MemoryReq 0&Type 0
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1"); // 预期结果 TC_CANTest SOA check Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1 //检查RESPONSE
}

