  TestDescription("二排左空调温度调节(远控) Power=Remote ON");
  teststep("warning","原始用例id为SYS-CDCU-温度调节-0588");
  gTC_CANTest_SOA_SetSever("TempSelectStStruct.RLTempSelectSt:32"); // 测试步骤 TC_CANTest SOA SetServer TempSelectStStruct.RLTempSelectSt:32//
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("2"); // 测试步骤 TC_Sleep 2
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_RLTempDownRespStruct.Veh_RLTempDownNRC 0"); // 预期结果 TC_CANTest SOA check Veh_RLTempDownRespStruct.Veh_RLTempDownNRC 0
  gTC_CANTest_SOA_CheckReq_Prepare("SetRLTempStruct.SetRLTemp 31.5&MemoryReq 0"); // 预期结果 TC_CANTest SOA CheckReq SetRLTempStruct.SetRLTemp 31.5&MemoryReq 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1"); // 预期结果 TC_CANTest SOA check Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1 //检查RESPONSE
  g_EM_SOAClient_Swc_SOA_REQ("Veh_RLTempDownStruct.Veh_RLTempDown:1&ServiceExecuteFeedbackFlag:2&UserID:0x01010001&Time:1"); // 测试步骤 TC_CANTest SOA REQ Veh_RLTempDownStruct.Veh_RLTempDown:1&ServiceExecuteFeedbackFlag:2&UserID:0x01010001&Time:1 //0.5步进
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_RLTempDownRespStruct.Veh_RLTempDownNRC 0"); // 预期结果 TC_CANTest SOA check Veh_RLTempDownRespStruct.Veh_RLTempDownNRC 0
  gTC_CANTest_SOA_CheckReq("SetRLTempStruct.SetRLTemp 31.5&MemoryReq 0"); // 预期结果 TC_CANTest SOA CheckReq SetRLTempStruct.SetRLTemp 31.5&MemoryReq 0
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1"); // 预期结果 TC_CANTest SOA check Veh_HVACService_ErrStruct.OpeNRC 0 delay8.1 //检查RESPONSE
}

