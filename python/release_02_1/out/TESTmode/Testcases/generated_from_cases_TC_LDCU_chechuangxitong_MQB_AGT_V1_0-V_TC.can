testcase SYS_LDCU_window_0001()
{
  TestDescription("初始化打开配置");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON//
  g_HIL_Bus_Swc_Set("J_DI_FLDoorAjarSW_LS close"); // 测试步骤 Step Set J_DI_FLDoorAjarSW_LS close
  g_HIL_Bus_Swc_Set("J_DI_RLDoorAjarSW_LS close"); // 测试步骤 Step Set J_DI_RLDoorAjarSW_LS close
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0"); // 测试步骤 Step Set I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0//CLOSE
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_RRDoorAjarSt 0"); // 测试步骤 Step Set I_RDCU_BodySysSt1::I_RDCU_RRDoorAjarSt 0//CLOSE
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_ComfortWndsCmd 0"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_ComfortWndsCmd 0//0x0:No_command
  g_HIL_Bus_Swc_Set("C_SRS_SysSt::C_SRS_CrashOutputSt 0"); // 测试步骤 Step Set C_SRS_SysSt::C_SRS_CrashOutputSt 0//Inactive
}

testcase SYS_LDCU_window_0002()
{
  TestDescription("SOA激活/关闭车窗锁止功能");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON//
  g_EM_SOAClient_Swc_SOA_FIND("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA FIND 0x0061 0x0002
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0005 WinLockCtrlReq:0x1&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0005 WinLockCtrlReq:0x1&UserID:1//0x1:Lock
  g_EM_SOAClient_Swc_SOA_CHECK("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("FLWindowStStruct.WinLockworkSt 1"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.WinLockworkSt 1//0x1:Active
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
  g_EM_SOAClient_Swc_SOA_CHECK("FLWindowStStruct.WinLockworkSt 1"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.WinLockworkSt 1//0x1:Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 1//Active
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0005 WinLockCtrlReq:0x2&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0005 WinLockCtrlReq:0x2&UserID:1//0x2:Unlock
  g_EM_SOAClient_Swc_SOA_CHECK("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("FLWindowStStruct.WinLockworkSt 0"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.WinLockworkSt 0//0x0:Inactive
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
  g_EM_SOAClient_Swc_SOA_CHECK("FLWindowStStruct.WinLockworkSt 0"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.WinLockworkSt 0//0x0:Inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0//
}

testcase SYS_LDCU_window_0003()
{
  TestDescription("SOA激活/关闭车窗锁止功能");
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF//
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 0"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 0//OFF
  g_EM_SOAClient_Swc_SOA_FIND("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA FIND 0x0061 0x0002
  g_HIL_Gen_Swc_Wait("62 s"); // 测试步骤 Step Wait 62 s
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0//
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 1&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 1&RespCode 0//0x1:PowerMode Not Fitted
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0005 WinLockCtrlReq:0x1&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0005 WinLockCtrlReq:0x1&UserID:1//0x1:Lock
  g_EM_SOAClient_Swc_SOA_CHECK("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 1&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 1&RespCode 0//0x1:PowerMode Not Fitted
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("FLWindowStStruct.WinLockworkSt 0"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.WinLockworkSt 0//0x0:Inactive
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
  g_EM_SOAClient_Swc_SOA_CHECK("FLWindowStStruct.WinLockworkSt 0"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.WinLockworkSt 0//0x0:Inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0//
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0005 WinLockCtrlReq:0x0&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0005 WinLockCtrlReq:0x0&UserID:1//
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
}

testcase SYS_LDCU_window_0004()
{
  TestDescription("SOA关闭锁车自动升窗功能");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON//
  g_EM_SOAClient_Swc_SOA_FIND("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA FIND 0x0061 0x0002
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("LockWinCfgRespStruct.LockWinCfgNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check LockWinCfgRespStruct.LockWinCfgNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0006 LockWinCfg:0x2&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0006 LockWinCfg:0x2&UserID:1//0x2:active
  g_EM_SOAClient_Swc_SOA_CHECK("LockWinCfgRespStruct.LockWinCfgNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check LockWinCfgRespStruct.LockWinCfgNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("FLWindowStStruct.LockWinCfgFB 1"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.LockWinCfgFB 1//0x1:Active
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
  g_EM_SOAClient_Swc_SOA_CHECK("FLWindowStStruct.LockWinCfgFB 1"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.LockWinCfgFB 1//0x1:Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LockWinCfgFB 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LockWinCfgFB 1//Active
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0006 LockWinCfg:0x1&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0006 LockWinCfg:0x1&UserID:1//0x1:not active
  g_EM_SOAClient_Swc_SOA_CHECK("WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check WinLockCtrlReqRespStruct.WinLockCtrlReqNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("FLWindowStStruct.LockWinCfgFB 0"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.LockWinCfgFB 0//0x0:Inactive
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
  g_EM_SOAClient_Swc_SOA_CHECK("FLWindowStStruct.LockWinCfgFB 0"); // 预期结果 TC_CANTest SOA check FLWindowStStruct.LockWinCfgFB 0//0x0:Inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LockWinCfgFB 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LockWinCfgFB  0//
}

testcase SYS_LDCU_window_0005()
{
  TestDescription("SOA响应大屏控制主驾车窗运动到指定位置");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON//
  g_EM_SOAClient_Swc_SOA_FIND("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA FIND 0x0061 0x0002
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("FLWinPosCmdRespStruct.FLWinPosCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check FLWinPosCmdRespStruct.FLWinPosCmdNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0001 FLWinPos:0&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0001 FLWinPos:0&UserID:1//手动输入0%
  g_EM_SOAClient_Swc_SOA_CHECK("FLWinPosCmdRespStruct.FLWinPosCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check FLWinPosCmdRespStruct.FLWinPosCmdNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
  g_HIL_Bus_Swc_Check("J_HBridge_FLCWindowCtr+ Up"); // 预期结果 Step Check J_HBridge_FLCWindowCtr+ Up
  g_HIL_Bus_Swc_Check("J_HBridge_FLCWindowCtr- OFF"); // 预期结果 Step Check J_HBridge_FLCWindowCtr- OFF
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_SOAClient_Swc_SOA_REQ("0x0061 0x0001 FLWinPos:0&UserID:1"); // 测试步骤 TC_CANTest SOA REQ 0x0061 0x0001 FLWinPos:0&UserID:1//
  g_EM_SOAClient_Swc_SOA_SUB("0x0061 0x0002"); // 测试步骤 TC_CANTest SOA SUB 0x0061 0x0002
}

