  TestDescription("左后车窗双档开关状态检测ManualDown LocalON->OFF 1min内");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON//
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//ON
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 0"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 0//OFF
  g_HIL_Bus_Swc_Set("J_AI_RLWindowCtrSw ManualDown"); // 测试步骤 Step Set J_AI_RLWindowCtrSw ManualDown//3
  g_HIL_Gen_Swc_Wait("601 ms"); // 测试步骤 Step Wait 601 ms//恢复初始状态
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_RLWinSwSt 3"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_RLWinSwSt 3//ManualDown
  g_HIL_Bus_Swc_Set("J_AI_RLWindowCtrSw NoInput"); // 测试步骤 Step Set J_AI_RLWindowCtrSw NoInput
}

