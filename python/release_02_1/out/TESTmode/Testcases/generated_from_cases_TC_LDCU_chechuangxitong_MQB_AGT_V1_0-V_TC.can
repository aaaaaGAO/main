testcase SYS_LDCU_window_0084()
{
  TestDescription("主驾左前车窗双档开关控制手动上升-车窗锁制开关未激活&LocalON");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON//
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//ON
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("J_AI_DFLWindowCtrSw NoInput"); // 测试步骤 Step Set J_AI_DFLWindowCtrSw NoInput//No Input
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_WinLockworkSt 0//inactive
  g_HIL_Bus_Swc_Set("J_AI_DFLWindowCtrSw ManualUp"); // 测试步骤 Step Set J_AI_DFLWindowCtrSw ManualUp//
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms//
  g_HIL_Bus_Swc_Check("J_HBridge_FLCWindowCtr+ Up"); // 预期结果 Step Check J_HBridge_FLCWindowCtr+ Up
  g_HIL_Bus_Swc_Check("J_HBridge_FLCWindowCtr- Stop"); // 预期结果 Step Check J_HBridge_FLCWindowCtr- Stop
  g_HIL_Bus_Swc_Check("I_LDCU_WinStFB1::I_LDCU_FLWinActionFB 1"); // 预期结果 Step Check I_LDCU_WinStFB1::I_LDCU_FLWinActionFB 1//0x1:Window_Closing
  g_HIL_Bus_Swc_Set("J_AI_DFLWindowCtrSw NoInput"); // 测试步骤 Step Set J_AI_DFLWindowCtrSw NoInput//No Input
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("I_LDCU_WinStFB2::I_LDCU_RLWinActionFB 0"); // 预期结果 Step Check I_LDCU_WinStFB2::I_LDCU_RLWinActionFB 0//0x0:Stopped,
  g_HIL_Bus_Swc_Check("J_HBridge_FLCWindowCtr+ Stop"); // 预期结果 Step Check J_HBridge_FLCWindowCtr+ Stop
  g_HIL_Bus_Swc_Check("J_HBridge_FLCWindowCtr- Stop"); // 预期结果 Step Check J_HBridge_FLCWindowCtr- Stop
}

