testcase SYS_LDCU_Powermode_0006()
{
  TestDescription("车内有合法钥匙时踩刹车按启动按钮上电-1");
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF//非强制下电
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 0"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 0//OFF
  g_HIL_Clib_Swc_Clib_Convenience(); // 测试步骤 Step Clib Convenience
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 3"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 3 //Convenience
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 1"); // 测试步骤 Step Set J_DI_BrakeSw2_HS Pressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 1"); // 测试步骤 Step Set J_DI_BrakeSw1_HS Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 1 1 s"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 1 1 s//Pressed
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1//valid
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s//Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerONSource 6 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerONSource 6 1 s//ZAT and Pedal Pressed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//Local ON
  g_HIL_Bus_Swc_Check("VTS::VT2848_2_Ch26::CurBit 1"); // 预期结果 Step Check J_DO_HS_KL15_BackUp Active
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 1
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 1
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s//NotActive
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw1_HS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw2_HS NotPressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 0"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 0//NotPressed
}

testcase SYS_LDCU_Powermode_0007()
{
  TestDescription("车内有合法钥匙时踩刹车按启动按钮上电-2");
  g_HIL_Clib_Swc_Clib_Convenience(); // 测试步骤 Step Clib Convenience
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 3"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 3 //Convenience
  g_HIL_Clib_Swc_Clib_P(); // 测试步骤 Step Clib P
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 1"); // 测试步骤 Step Set J_DI_BrakeSw2_HS Pressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 1"); // 测试步骤 Step Set J_DI_BrakeSw1_HS Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 1 1 s"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 1 1 s//Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1//valid
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s//Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerONSource 6 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerONSource 6 1 s//ZAT and Pedal Pressed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//Local ON
  g_HIL_Bus_Swc_Check("VTS::VT2848_2_Ch26::CurBit 1"); // 预期结果 Step Check J_DO_HS_KL15_BackUp Active
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 1
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 1
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s//NotActive
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw1_HS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw2_HS NotPressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 0"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 0//NotPressed
}

testcase SYS_LDCU_Powermode_0008()
{
  TestDescription("车内有合法钥匙时按启动按钮上电");
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF//非强制下电
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 0"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 0//OFF
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw1_HS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw2_HS NotPressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 0"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 0//Not Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1//valid
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s//Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerONSource 5 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerONSource 5 1 s//Only ZAT Pressed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//Local ON
  g_HIL_Bus_Swc_Check("VTS::VT2848_2_Ch26::CurBit 1"); // 预期结果 Step Check J_DO_HS_KL15_BackUp Active
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 1
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 1
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s//NotActive
}

testcase SYS_LDCU_Powermode_0009()
{
  TestDescription("车内有合法钥匙时踩刹车按启动按钮上电-1");
  g_HIL_Clib_Swc_Clib_ForceOFF(); // 测试步骤 Step Clib ForceOFF//强制下电
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerOFFSource 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerOFFSource 2//强制下电
  g_HIL_Clib_Swc_Clib_P(); // 测试步骤 Step Clib P
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 1"); // 测试步骤 Step Set J_DI_BrakeSw2_HS Pressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 1"); // 测试步骤 Step Set J_DI_BrakeSw1_HS Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 1 1 s"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 1 1 s//Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1//valid
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s//Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerONSource 6 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerONSource 6 1 s//ZAT and Pedal Pressed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//Local ON
  g_HIL_Bus_Swc_Check("VTS::VT2848_2_Ch26::CurBit 1"); // 预期结果 Step Check J_DO_HS_KL15_BackUp Active
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 1
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 1
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s//NotActive
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw1_HS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw2_HS NotPressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 0"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 0//NotPressed
}

