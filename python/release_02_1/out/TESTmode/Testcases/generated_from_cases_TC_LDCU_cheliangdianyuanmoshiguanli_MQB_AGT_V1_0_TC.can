  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 2"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 2//RemoteON
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch17::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw1_HS NotPressed
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch22::DigitalOutput 0"); // 测试步骤 Step Set J_DI_BrakeSw2_HS NotPressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalSt 0"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalSt 0//Not Pressed
  g_HIL_Bus_Swc_Check("C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1"); // 预期结果 Step Check C_LDCU_SysSt::C_LDCU_BrkPedalStVD 1//valid
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 0
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 1"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 1 1 s//Active
  g_HIL_XCP_Swc_Set_XCP("CalVal_KeyValidSt 1"); // 测试步骤 Step Set_XCP CalVal_KeyValidSt 1
  g_HIL_XCP_Swc_Set_XCP("CalEn_KeyValidSt 80"); // 测试步骤 Step Set_XCP CalEn_KeyValidSt 80
  g_HIL_Bus_Swc_Check("I_LDCU_Debug::I_KeyValidSt 1 1 s"); // 预期结果 Step Check I_LDCU_Debug::I_KeyValidSt 1 1 s//valid
  g_HIL_Gen_Swc_Wait("2 s"); // 测试步骤 Step Wait 2 s
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerONSource 5 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerONSource 5 1 s//ZAT and Pedal Pressed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//Local ON
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch27::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin4SW_LS 1
  g_HIL_Bus_Swc_Check("VTS::VT2848_2_Ch26::CurBit 1"); // 预期结果 Step Check J_DO_HS_KL15_BackUp Active
  g_HIL_Bus_Swc_Set("VTS::VT2848_4_Ch32::DigitalOutput 0"); // 测试步骤 Step Set J_DI_SSBPin6SW_LS 1
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_ZATButtonSwSt 0 1 s//NotActive
}

