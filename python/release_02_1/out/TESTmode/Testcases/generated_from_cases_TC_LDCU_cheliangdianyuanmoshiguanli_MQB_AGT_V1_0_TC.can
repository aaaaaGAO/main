  g_HIL_Bus_Swc_Check("C_Motor_14::C_MO_Motor_laeuft 0"); // 预期结果 Step Check C_Motor_14::C_MO_Motor_laeuft 0//Motor_laeuft_nicht
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1 //LocalON
  g_HIL_Clib_Swc_Clib_P(); // 测试步骤 Step Clib P
  g_HIL_Bus_Swc_Set("C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 4"); // 测试步骤 Step Set C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 4//Slient OTA
  g_HIL_Gen_Swc_Wait("100 ms"); // 测试步骤 Step Wait 100 ms
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0"); // 测试步骤 Step Set J_DI_FLDoorAjarSW_LS 1//Close
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 1"); // 测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0//Open
  g_HIL_Bus_Swc_Check("I_LDCU_NM::I_LDCU_FLDoorAjarSW 1"); // 预期结果 Step Check I_LDCU_NM::I_LDCU_FLDoorAjarSW 1//Active
  g_HIL_Gen_Swc_Wait("100 ms"); // 测试步骤 Step Wait 100 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 2 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 2 1 s//Remote ON
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_PowerONSource 3"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_PowerONSource 3//OTA/Remote Diag Req
  g_HIL_Bus_Swc_Set("C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0"); // 测试步骤 Step Set C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0//No diagnostic
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 0"); // 测试步骤 Step Set J_DI_FLDoorAjarSW_LS 1//Close
  g_HIL_Clib_Swc_Clib_RemoteOFF(); // 测试步骤 Step Clib RemoteOFF
}

