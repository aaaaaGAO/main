testcase SYS_LDCU_Powermode_0119()
{
  TestDescription("实体开关仲裁-1");
  g_HIL_UDS_Swc_Set_UDS("SA_L1"); // 测试步骤 Step Set_UDS SA_L1
  g_HIL_Gen_Swc_Wait("151 ms"); // 测试步骤 Step Wait 151 ms
  g_HIL_UDS_Swc_Set_UDS("2E 31 11 02 00"); // 测试步骤 Step Set_UDS 2E 31 11 02 00//Dbldigital
  g_HIL_UDS_Swc_Check_UDS("6E 31 11"); // 预期结果 Step Check_UDS 6E 31 11//Dbldigital
