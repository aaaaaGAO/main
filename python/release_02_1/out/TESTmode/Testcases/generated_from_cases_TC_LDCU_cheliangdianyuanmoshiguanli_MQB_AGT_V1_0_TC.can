  g_HIL_Bus_Swc_Check("I_LDCU_State::I_KeySearchingSt 0 1 s"); // 预期结果 Step Check I_LDCU_State::I_KeySearchingSt 0 1 s//Not Searching
  g_HIL_Gen_Swc_Wait("100 ms"); // 测试步骤 Step Wait 100 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_KeyInvalidAlertReq 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_KeyInvalidAlertReq 2//Key not found Alert3帧
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
