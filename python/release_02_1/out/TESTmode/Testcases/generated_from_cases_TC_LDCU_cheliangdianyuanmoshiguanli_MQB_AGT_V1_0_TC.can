  g_HIL_Bus_Swc_Set("I_CDCU_InvolvingSafety_Ctrl::I_CDCU_LDCU_2ndOffResult 0"); // 测试步骤 Step Set I_CDCU_InvolvingSafety_Ctrl::I_CDCU_LDCU_2ndOffResult 0
}

