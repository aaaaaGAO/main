testcase SYS_LDCU_Powermode_0035()
{
  TestDescription("离车时激活了远程诊断或者OTA功能-1");
  g_HIL_XCP_Swc_Set_XCP("CalEn_Vcu_MO_Motor_laeuft 1"); // 测试步骤 Step Set_XCP CalEn_Vcu_MO_Motor_laeuft 1
