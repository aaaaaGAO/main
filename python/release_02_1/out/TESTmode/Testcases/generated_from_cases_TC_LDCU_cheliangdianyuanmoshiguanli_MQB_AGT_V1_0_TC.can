testcase SYS_LDCU_Powermode_0038()
{
  TestDescription("退出远程诊断或OTA车辆下电-1");
  g_HIL_XCP_Swc_Set_XCP("CalC_tPwMdOTAPwrOnValid 10"); // 测试步骤 Step Set_XCP CalC_tPwMdOTAPwrOnValid 10
  g_HIL_Clib_Swc_Clib_RemoteON(); // 测试步骤 Step Clib RemoteON
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 2"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 2 //RemoteOn
  g_HIL_Clib_Swc_Clib_P(); // 测试步骤 Step Clib P
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_CurMode 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_CurMode 0// 智能驾驶模式Invalid
  g_HIL_Bus_Swc_Check("I_LDCU_State::I_OTAPowerOnValid 1"); // 预期结果 Step Check I_LDCU_State::I_OTAPowerOnValid 1//VALID
  g_HIL_Bus_Swc_Set("C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0"); // 测试步骤 Step Set C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0
