testcase SYS_LDCU_Powermode_0079()
{
  TestDescription("延时自动下电功能激活与退出-6");
  g_HIL_XCP_Swc_Set_XCP("CalEn_Vcu_MO_Motor_laeuft 1"); // 测试步骤 Step Set_XCP CalEn_Vcu_MO_Motor_laeuft 1
  g_HIL_XCP_Swc_Set_XCP("CalVal_Vcu_MO_Motor_laeuft 0"); // 测试步骤 Step Set_XCP CalVal_Vcu_MO_Motor_laeuft 0
  g_HIL_Bus_Swc_Check("C_Motor_14::C_MO_Motor_laeuft 0"); // 预期结果 Step Check C_Motor_14::C_MO_Motor_laeuft 0//Motor_laeuft_nicht
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_PowerMode 1"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_PowerMode 1//Local on
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 0"); // 测试步骤 Step Set I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 0
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 1"); // 测试步骤 Step Set I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 1//自动下电功能INACTIVE
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt3::I_LDCU_AutoPoweroffCfgSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt3::I_LDCU_AutoPoweroffCfgSt 0//inactive
  g_HIL_Bus_Swc_Set("C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0"); // 测试步骤 Step Set C_CDCU_DiagnosticSt::C_CDCU_DiagnosticSt 0
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfoF::C_IPB_VehSpd 0"); // 测试步骤 Step Set C_IPB_SpdInfoF::C_IPB_VehSpd 0//车速小于3Km
  g_HIL_Bus_Swc_Set("C_IPB_SpdInfoF::C_IPB_VehSpdVD 1"); // 测试步骤 Step Set C_IPB_SpdInfoF::C_IPB_VehSpdVD 1//车速有效
  g_HIL_Clib_Swc_Clib_P(); // 测试步骤 Step Clib P
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_CurMode 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_CurMode 0// 智能驾驶模式Invalid
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_AutoPowerOffDisableReq 0"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_AutoPowerOffDisableReq 0//No Command
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 0"); // 测试步骤 Step Set I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 0
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 2"); // 测试步骤 Step Set I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 2//自动下电功能ACTIVE
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt3::I_LDCU_AutoPoweroffCfgSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt3::I_LDCU_AutoPoweroffCfgSt 1//active
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 0"); // 测试步骤 Step Set I_CDCU_LDCU_Ctrl::I_CDCU_AutoPoweroffConfig 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt3::I_LDCU_AutoPowerOffFuncSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt3::I_LDCU_AutoPowerOffFuncSt 1//30min Count Down Started(T1计时）
  g_HIL_Clib_Swc_Clib_R(); // 测试步骤 Step Clib R
  g_HIL_Gen_Swc_Wait("101 ms"); // 测试步骤 Step Wait 101 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt3::I_LDCU_AutoPowerOffFuncSt 3"); // 预期结果 Step Check I_LDCU_BodySysSt3::I_LDCU_AutoPowerOffFuncSt 3//Count Down Canceled（持续300ms）
  g_HIL_Clib_Swc_Clib_P(); // 测试步骤 Step Clib P
}

