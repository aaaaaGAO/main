  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatStStruct.RearMirrorHeatOutputSt 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatStStruct.RearMirrorHeatOutputSt 0
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatStStruct.RearMirrorHeatOutputSt 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatStStruct.RearMirrorHeatOutputSt 0
