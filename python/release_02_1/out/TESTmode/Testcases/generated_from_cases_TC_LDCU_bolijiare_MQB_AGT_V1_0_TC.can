testcase SYS_LDCU_RearMirrorHeat_028()
{
  TestDescription("左外后视镜加热开启&关闭（实体按键)");
  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON
  g_HIL_Bus_Swc_Set("J_BAT_VOLT_SV 13.5"); // 测试步骤 Step Set J_BAT_VOLT_SV 13.5//蓄电池电压=13.5V
  // Step Set_CF05 MirrorHeatedTypeCfg enable // 测试步骤Set_CF05关键字不存在
  teststep("step","Step Set_CF05 MirrorHeatedTypeCfg enable");
  teststepfail("fail","Set_CF05关键字不存在");
  g_HIL_Gen_Swc_Wait("201 ms"); // 测试步骤 Step Wait 201 ms
  g_HIL_Bus_Swc_Check("I_RDCU_BodySysSt3::I_RDCU_RightMirrorHeatOutputSt 0"); // 预期结果 Step Check I_RDCU_BodySysSt3::I_RDCU_RightMirrorHeatOutputSt 0
  g_HIL_Bus_Swc_Set("J_AI_MirrorHeatFoldAdjSw 2.6"); // 测试步骤 Step Set  J_AI_MirrorHeatFoldAdjSw 2.6//J5-38
  g_HIL_Gen_Swc_Wait("201 ms"); // 测试步骤 Step Wait 201 ms
  g_HIL_Bus_Swc_Check("I_LDCU_SshdCtrl::I_MirrorSwSts 4 1 s"); // 预期结果 Step Check I_LDCU_SshdCtrl::I_MirrorSwSts 4 1 s//0x4:Heat
  g_HIL_Bus_Swc_Check("J_DO_HS_LeftMirrorHeated 1"); // 预期结果 Step Check J_DO_HS_LeftMirrorHeated 1//0x1 Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 1 1 s//0x1:Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 1"); // 预期结果 Step Check I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 1//0x1:Open
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Set("J_AI_MirrorHeatFoldAdjSw 3"); // 测试步骤 Step Set J_AI_MirrorHeatFoldAdjSw 3//J5-38 断路为N档
  g_HIL_Gen_Swc_Wait("302 ms"); // 测试步骤 Step Wait 302 ms
  g_HIL_Bus_Swc_Check("I_LDCU_SshdCtrl::I_MirrorSwSts 0"); // 预期结果 Step Check I_LDCU_SshdCtrl::I_MirrorSwSts 0//0x0 Neutral
  g_HIL_Bus_Swc_Check("I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 2"); // 预期结果 Step Check I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 2//0x2:close
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0//0x1:Not active
  g_HIL_Bus_Swc_Check("J_DO_HS_LeftMirrorHeated Inactive"); // 预期结果 Step Check J_DO_HS_LeftMirrorHeated Inactive
}

