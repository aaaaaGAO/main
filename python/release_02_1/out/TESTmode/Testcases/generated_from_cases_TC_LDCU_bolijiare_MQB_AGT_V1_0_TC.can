testcase SYS_LDCU_CameraHeated_001()
{
  TestDescription("摄像头加热\\ 开启&关闭\\ OFF时关闭\\");
  g_HIL_Bus_Swc_Set("VTS::VT2004_1::RelaySwapBusBar1A 0"); // 测试步骤 Step Set VTS::VT2004_1::RelaySwapBusBar1A  0//蓄电池电压=13.5V
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0//0x0:no Command
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 1"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 1//0x1:Requestheating
  g_HIL_Sysvar_Swc_KeepShToGNDWithTime("J_HBridge_FLHandleCtr+ 100 MS 200"); // 预期结果 KeepShToGNDWithTime J_HBridge_FLHandleCtr+ 100 MS 200
  g_HIL_Bus_Swc_Check("J_AI_FRWindowCtrSw_DTC_TOPOW Inactive"); // 测试步骤 Step Check J_AI_FRWindowCtrSw_DTC_TOPOW Inactive //inactive 输出低
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Active"); // 预期结果 Step Check J_DO_HS_CameraHeated Active //active,J2-25,高有效
  g_HIL_Bus_Swc_Check("J_AI_FRWindowCtrSw_DTC_TOGND 100 s"); // 测试步骤 Step  Check J_AI_FRWindowCtrSw_DTC_TOGND 100 s
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 1//0x1:Heating
  g_HIL_Bus_Swc_Check("J_AI_FRWindowCtrSw_DTC_TOGND Inactive"); // 测试步骤 Step Check J_AI_FRWindowCtrSw_DTC_TOGND Inactive //inactive 输出低
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Inactive"); // 预期结果 Step Check J_DO_HS_CameraHeated Inactive //inactive 输出低
  g_HIL_Sysvar_Swc_KeepOpenWithTime("J_AI_FRWindowCtrSw_DTC_TOPOW 100 200 ms"); // 测试步骤 KeepOpenWithTime J_AI_FRWindowCtrSw_DTC_TOPOW 100 200 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0//0x0:no Heating
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0//0x0:no Command
  g_HIL_Sysvar_Swc_KeepShToPOWWithTime("ABC 100 MS 200"); // 预期结果 KeepShToPOWWithTime  ABC 100 MS 200
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
  g_HIL_Sysvar_Swc_KeepOverCurWithTime("J_AI_WinLockOrChildlockSw 100 MS 200"); // 预期结果 Step KeepOverCurWithTime   J_AI_WinLockOrChildlockSw 100 MS 200
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Inactive"); // 预期结果 Step Check J_DO_HS_CameraHeated Inactive //inactive
  g_HIL_Sysvar_Swc_KeepOpenWithTime("roofmoduleConfig 123"); // 测试步骤 KeepOpenWithTime roofmoduleConfig 123
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0//0x0:no Heating
}

testcase SYS_LDCU_CameraHeated_002()
{
  TestDescription("摄像头加热/ 开启&关闭\\\ XPU Stop heating请求关闭\\");
  g_HIL_Bus_Swc_Set("J_BAT_VOLT_SV 13.5"); // 测试步骤 Step Set J_BAT_VOLT_SV 13.5//蓄电池电压=13.5V
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0//0x0:no Command
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 1"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 1//0x1:Requestheating
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Active"); // 预期结果 Step Check J_DO_HS_CameraHeated Active //active J2-25输出高
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 1//0x1:Heating;
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 2"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 2//0x2:Stop heating
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Inactive"); // 预期结果 Step Check J_DO_HS_CameraHeated Inactive //inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0//0x0:no Heating
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0//0x0:no Command
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
}

testcase SYS_LDCU_CameraHeated_003()
{
  TestDescription("摄像头加热\\开启&关闭\\丢失通信关闭");
  g_HIL_Bus_Swc_Set("J_BAT_VOLT_SV 13.5"); // 测试步骤 Step Set J_BAT_VOLT_SV 13.5//蓄电池电压=13.5V
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0//0x0:no Command
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 1"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 1//0x1:Requestheating
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Active"); // 预期结果 Step Check J_DO_HS_CameraHeated Active //active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 1//0x1:Heating;
  g_HIL_Bus_Swc_Disable_ID("I_XPU_BodyCtrl"); // 测试步骤 Step Disable_ID I_XPU_BodyCtrl//通信丢失
  g_HIL_Gen_Swc_Wait("5 s"); // 测试步骤 Step Wait 5 s
  g_HIL_Bus_Swc_Check("J_DO_HS_CameraHeated Inactive"); // 预期结果 Step Check J_DO_HS_CameraHeated Inactive //inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_XPU_HeatFeedBack 0//0x0:no Heating
  g_HIL_Bus_Swc_Enable_ID("I_XPU_BodyCtrl"); // 测试步骤 Step Enable_ID I_XPU_BodyCtrl//通信恢复
  g_HIL_Gen_Swc_Wait("501 ms"); // 测试步骤 Step Wait 501 ms
  g_HIL_Bus_Swc_Set("I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0"); // 测试步骤 Step Set I_XPU_BodyCtrl::I_XPU_LDCU_HeatReq 0//0x0:no Command
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
}

testcase SYS_LDCU_RearMirrorHeat_001()
{
  TestDescription("后挡风玻璃加热 开启&关闭");
  // Step Set_CF05 DefrostCfg enable//byte 1 // 测试步骤Set_CF05关键字不存在
  teststep("step","Step Set_CF05 DefrostCfg enable//byte 1");
  teststepfail("fail","Set_CF05关键字不存在");
  g_HIL_Bus_Swc_Set("J_BAT_VOLT_SV 13.5"); // 测试步骤 Step Set J_BAT_VOLT_SV 13.5//蓄电池电压=13.5V
  g_EM_SOAClient_Swc_SOA_SubPeriod("RearMirrorHeatSt 1"); // 测试步骤 TC_CANTest SOA SubPeriod RearMirrorHeatSt 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("RearMirrorHeatService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod RearMirrorHeatService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_REQ("RearMirrorHeatCmdStruct.RearMirrorHeat:1&userid:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ RearMirrorHeatCmdStruct.RearMirrorHeat:1&userid:1&ServiceExecuteFeedbackFlag:2//0x1:Open
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0//
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatService_ErrStruct.OpeNRC 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatService_ErrStruct.OpeNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatStStruct.RearMirrorHeatOutputSt 1"); // 预期结果 TC_CANTest SOA check RearMirrorHeatStStruct.RearMirrorHeatOutputSt 1//Active
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0//
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatService_ErrStruct.OpeNRC 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatService_ErrStruct.OpeNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatStStruct.RearMirrorHeatOutputSt 1"); // 预期结果 TC_CANTest SOA check RearMirrorHeatStStruct.RearMirrorHeatOutputSt 1//Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 1//Active
  g_HIL_Bus_Swc_Check("J_DO_LS_DeforstrRly Active"); // 预期结果 Step Check J_DO_LS_DeforstrRly Active//输出加热驱动，IO=J1-15,低有效
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 1//后除霜输出状态active
  g_EM_SOAClient_Swc_SOA_REQ("RearMirrorHeatCmdStruct.RearMirrorHeat:2&userid:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ RearMirrorHeatCmdStruct.RearMirrorHeat:2&userid:1&ServiceExecuteFeedbackFlag:2//0x2:close
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0//
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("RearMirrorHeatService_ErrStruct.OpeNRC 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatService_ErrStruct.OpeNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatCmdRespStruct.RearMirrorHeatCmdNRC 0&RespCode 0//
  g_EM_SOAClient_Swc_SOA_CHECK("RearMirrorHeatService_ErrStruct.OpeNRC 0"); // 预期结果 TC_CANTest SOA check RearMirrorHeatService_ErrStruct.OpeNRC 0
  g_HIL_Bus_Swc_Check("J_DO_LS_DeforstrRly 1"); // 预期结果 Step Check J_DO_LS_DeforstrRly 1//输出加热驱动，IO=J1-15,低有效
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 0//后除霜输出状态Not active
  g_EM_SOAClient_Swc_SOA_StopSubPeriod(); // 测试步骤 TC_CANTest SOA StopSubPeriod
}

testcase SYS_LDCU_RearMirrorHeat_002()
{
  TestDescription("后挡风玻璃加热开启       低压未开启");
  g_HIL_Bus_Swc_Set("J_BAT_VOLT_SV 7.5"); // 测试步骤 Step Set J_BAT_VOLT_SV 7.5//蓄电池低压=7.5V
