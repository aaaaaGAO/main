  g_HIL_Clib_Swc_Clib_LocalON(); // 测试步骤 Step Clib LocalON
  g_HIL_Bus_Swc_Set("J_BAT_VOLT_SV 13.5"); // 测试步骤 Step Set J_BAT_VOLT_SV 13.5//蓄电池电压=13.5V
  g_HIL_Clib_Swc_Clib_NormalOTA(); // 测试步骤 Step Clib NormalOTA
  g_HIL_Bus_Swc_Set("J_AI_MirrorHeatFoldAdjSw >= 2 and <= 2.9"); // 测试步骤 Step Set  J_AI_MirrorHeatFoldAdjSw >= 2 and <= 2.9//J5-38
  g_HIL_Gen_Swc_Wait("201 ms"); // 测试步骤 Step Wait 201 ms
  g_HIL_Bus_Swc_Check("I_LDCU_SshdCtrl::I_MirrorSwSts 0"); // 预期结果 Step Check I_LDCU_SshdCtrl::I_MirrorSwSts 0//0x0 Neutral
  g_HIL_Bus_Swc_Check("I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 2"); // 预期结果 Step Check I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 2//0x2:close
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0//0x1:Not active
  g_HIL_Bus_Swc_Check("J_DO_HS_LeftMirrorHeated Inactive"); // 预期结果 Step Check J_DO_HS_LeftMirrorHeated Inactive
  g_HIL_Clib_Swc_Clib_NonOTA(); // 测试步骤 Step Clib NonOTA
}

testcase SYS_LDCU_RearMirrorHeat_034()
{
  TestDescription("镜片加热输出状态 Active&Not active");
  g_EM_SOAClient_Swc_SOA_SubPeriod("RearMirrorHeatSt 1"); // 测试步骤 TC_CANTest SOA SubPeriod RearMirrorHeatSt 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("RearMirrorHeatService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod RearMirrorHeatService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_REQ("RearMirrorHeatCmdStruct.RearMirrorHeat:1&userid:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ RearMirrorHeatCmdStruct.RearMirrorHeat:1&userid:1&ServiceExecuteFeedbackFlag:2//0x1:Open
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 1//0x1:Active
  g_HIL_Bus_Swc_Check("I_RDCU_BodySysSt3::I_RDCU_RightMirrorHeatOutputSt 0"); // 预期结果 Step Check I_RDCU_BodySysSt3::I_RDCU_RightMirrorHeatOutputSt 0//0x0 Not active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 1//0x1 Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt3::I_IMSHeatingSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt3::I_IMSHeatingSt 0//0x0 OFF
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_MirrorHeatOutputSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_MirrorHeatOutputSt 1//0x1 Active
  g_EM_SOAClient_Swc_SOA_REQ("RearMirrorHeatCmdStruct.RearMirrorHeat:2&userid:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ RearMirrorHeatCmdStruct.RearMirrorHeat:2&userid:1&ServiceExecuteFeedbackFlag:2//0x2:Open
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0//0x0:Not active
  g_HIL_Bus_Swc_Check("I_RDCU_BodySysSt3::I_RDCU_RightMirrorHeatOutputSt 0"); // 预期结果 Step Check I_RDCU_BodySysSt3::I_RDCU_RightMirrorHeatOutputSt 0//0x0 Not active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_RearMirrorHeatOutputSt 0//0x0:Not active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt3::I_IMSHeatingSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt3::I_IMSHeatingSt 0//0x0 OFF
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_MirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_MirrorHeatOutputSt 0//0x0:Not active
  g_EM_SOAClient_Swc_SOA_StopSubPeriod(); // 测试步骤 TC_CANTest SOA StopSubPeriod
}
