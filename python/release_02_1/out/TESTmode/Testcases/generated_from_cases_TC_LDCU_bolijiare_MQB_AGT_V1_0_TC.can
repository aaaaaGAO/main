  g_HIL_Bus_Swc_Check("I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 1"); // 预期结果 Step Check I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 1//0x1:Open
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 1//0x1:Active
  g_HIL_Bus_Swc_Check("J_DO_HS_LeftMirrorHeated Active"); // 预期结果 Step Check J_DO_HS_LeftMirrorHeated Active// 后视镜加热状态
  g_HIL_Clib_Swc_Clib_NormalOTA(); // 测试步骤 Step Clib NormalOTA
  g_EM_SOAClient_Swc_SOA_REQ("RearMirrorHeatCmdStruct.RearMirrorHeat:0&userID:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ RearMirrorHeatCmdStruct.RearMirrorHeat:0&userID:1&ServiceExecuteFeedbackFlag:2//0x0:no operation
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("J_DO_HS_LeftMirrorHeated Inactive"); // 预期结果 Step Check J_DO_HS_LeftMirrorHeated Inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_LeftMirrorHeatOutputSt 0//左后视镜输出状态0x0:Not active
  g_HIL_Bus_Swc_Check("I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 2"); // 预期结果 Step Check I_LDCU_BodyCtrl::I_LDCU_RDCU_RMirrorHeat 2// 0x2:Close
  g_HIL_Clib_Swc_Clib_NonOTA(); // 测试步骤 Step Clib NonOTA
  g_EM_SOAClient_Swc_SOA_StopSubPeriod(); // 测试步骤 TC_CANTest SOA StopSubPeriod
}

