  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("350"); // 测试步骤 TC_Sleep 350
  g_EM_Uart_Swc_Ser_CheckRaw("1070080002"); // 预期结果 TC_CANTest Ser CheckRaw 1070080002 // (MCU 通知SOC电源模式切换SLEEP)
}

