  gTC_CANTest_SOA_CheckReq("SetDrvSeatHeatingStruct.DrvSeatHeatingReq 3 traceback2"); // 预期结果 TC_CANTest SOA CheckReq SetDrvSeatHeatingStruct.DrvSeatHeatingReq 3 traceback2
}
