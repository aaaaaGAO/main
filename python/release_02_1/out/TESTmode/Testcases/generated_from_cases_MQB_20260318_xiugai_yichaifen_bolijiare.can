testcase SYS_CDCU_bolijiare_0007()
{
  TestDescription("开启前挡风玻璃加热 Power=Remote ON");
  teststep("warning","原始用例id为SYS-CDCU-玻璃加热-0007");
  g_EM_Equipment_Swc_TC_IG("ON"); // 测试步骤 TC_IG ON
  g_CAN_Bus_Swc_Set("I_LDCU_BodySysSt1.I_LDCU_PowerMode 2"); // 测试步骤 TC_CANTest SET I_LDCU_BodySysSt1.I_LDCU_PowerMode 2
  g_CAN_Bus_Swc_Set("C_LDCU_SysSt.C_LDCU_EVSysReadySt 2"); // 测试步骤 TC_CANTest SET C_LDCU_SysSt.C_LDCU_EVSysReadySt 2//ready
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0
  gTC_CANTest_SOA_CheckReq_Prepare("FrontMirrorHeatCmdStruct.FrontMirrorHeat 1 traceback3"); // 预期结果 TC_CANTest SOA CheckReq FrontMirrorHeatCmdStruct.FrontMirrorHeat 1 traceback3
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 traceback3"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 traceback3 //
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_FrontMirrorHeatService_ErrStruct.OpeErrInfo[0-1]:0x00C8 traceback3"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatService_ErrStruct.OpeErrInfo[0-1]:0x00C8 traceback3 //远控类服务返回码，控制成功
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("SOAEngineInterSignalStruct.FrontMirrorHeatHVReq 1"); // 预期结果 TC_CANTest SOA check SOAEngineInterSignalStruct.FrontMirrorHeatHVReq 1//请求上高压
  g_EM_SOAClient_Swc_SOA_REQ("Veh_FrontMirrorHeatStruct.Veh_FrontMirrorHeat:1&ServiceExecuteFeedbackFlag:2&UserID:0x01010001&Time:1"); // 测试步骤 TC_CANTest SOA REQ Veh_FrontMirrorHeatStruct.Veh_FrontMirrorHeat:1&ServiceExecuteFeedbackFlag:2&UserID:0x01010001&Time:1 //Open
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0
  gTC_CANTest_SOA_CheckReq("FrontMirrorHeatCmdStruct.FrontMirrorHeat 1 traceback3"); // 预期结果 TC_CANTest SOA CheckReq FrontMirrorHeatCmdStruct.FrontMirrorHeat 1 traceback3
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 traceback3"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 traceback3 //
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_FrontMirrorHeatService_ErrStruct.OpeErrInfo[0-1]:0x00C8 traceback3"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatService_ErrStruct.OpeErrInfo[0-1]:0x00C8 traceback3 //远控类服务返回码，控制成功
  g_EM_SOAClient_Swc_SOA_CHECK("SOAEngineInterSignalStruct.FrontMirrorHeatHVReq 1"); // 预期结果 TC_CANTest SOA check SOAEngineInterSignalStruct.FrontMirrorHeatHVReq 1//请求上高压
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("60"); // 测试步骤 TC_Sleep 60
  gTC_CANTest_SOA_CheckReq_Prepare("HighVoltageCtrlStruct.HighVoltageCtrl 2 traceback60"); // 预期结果 TC_CANTest SOA CheckReq HighVoltageCtrlStruct.HighVoltageCtrl 2 traceback60//请求上高压
  gTC_CANTest_SOA_CheckReq("HighVoltageCtrlStruct.HighVoltageCtrl 2 traceback60"); // 预期结果 TC_CANTest SOA CheckReq HighVoltageCtrlStruct.HighVoltageCtrl 2 traceback60//请求上高压
}

