testcase SYS_CDCU_bolijiare_0001()
{
  TestDescription("开启前挡风玻璃加热 Power=ON");
  teststep("warning","原始用例id为SYS-CDCU-玻璃加热-0001");
  g_EM_Equipment_Swc_TC_PW("ON"); // 测试步骤 TC_PW ON
  g_CAN_Bus_Swc_AllCANDataDefaultAllCh(); // 测试步骤 TC_CANTest SET AllCANDataDefaultAllCh
  g_EM_Equipment_Swc_TC_IG("ON"); // 测试步骤 TC_IG ON
  g_CAN_Bus_Swc_Set("I_LDCU_BodySysSt1.I_LDCU_PowerMode 1"); // 测试步骤 TC_CANTest SET I_LDCU_BodySysSt1.I_LDCU_PowerMode 1
  gTC_CANTest_SOA_Set8001Delay("0"); // 测试步骤 TC_CANTest SOA Set8001Delay 0
  g_CAN_Bus_Swc_Set("C_LDCU_SysSt.C_LDCU_EVSysReadySt 2"); // 测试步骤 TC_CANTest SET C_LDCU_SysSt.C_LDCU_EVSysReadySt 2//上高压
  g_EM_SOAClient_Swc_SOA_SubPeriod("Veh_FrontMirrorHeatService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod Veh_FrontMirrorHeatService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("Veh_RearMirrorHeatService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod Veh_RearMirrorHeatService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0
  gTC_CANTest_SOA_CheckReq_Prepare("FrontMirrorHeatCmdStruct.FrontMirrorHeat 1"); // 预期结果 TC_CANTest SOA CheckReq FrontMirrorHeatCmdStruct.FrontMirrorHeat 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 delay6.8"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 delay6.8 //
  g_EM_SOAClient_Swc_SOA_REQ("Veh_FrontMirrorHeatStruct.Veh_FrontMirrorHeat:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ Veh_FrontMirrorHeatStruct.Veh_FrontMirrorHeat:1&ServiceExecuteFeedbackFlag:2 //Open
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatRespStruct.Veh_FrontMirrorHeatNRC 0
  gTC_CANTest_SOA_CheckReq("FrontMirrorHeatCmdStruct.FrontMirrorHeat 1"); // 预期结果 TC_CANTest SOA CheckReq FrontMirrorHeatCmdStruct.FrontMirrorHeat 1
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 delay6.8"); // 预期结果 TC_CANTest SOA check Veh_FrontMirrorHeatService_ErrStruct.OpeNRC 0 delay6.8 //
}

