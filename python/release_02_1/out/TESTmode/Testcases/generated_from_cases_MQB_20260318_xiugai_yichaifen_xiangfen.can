testcase SYS_CDCU_xiangfen_0215()
{
  TestDescription("SFS从节点通信异常 U2F2C08");
  teststep("warning","原始用例id为SYS-CDCU-香氛-0215");
  g_CAN_Bus_Swc_Set("C_LDCU_SysSt.C_LDCU_EVSysReadySt 2"); // 测试步骤 TC_CANTest SET C_LDCU_SysSt.C_LDCU_EVSysReadySt 2//上高压
  g_EM_LIN_Swc_LIN_Send("C4_FRS_ResponseError 0x1 CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_ResponseError 0x1 CH4
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("3"); // 测试步骤 TC_Sleep 3
  g_EM_UDS_CAN_Swc_Diag("19 04 EF 2C 08 FF"); // 测试步骤 TC_CANTest Diag 19 04 EF 2C 08 FF
  g_EM_UDS_CAN_Swc_TC_CheckDiagRes("59 04 EF 2C 08 29 01 *"); // 预期结果 TC_CheckDiagRes 59 04 EF 2C 08 29 01 *
  g_EM_LIN_Swc_LIN_Send("C4_FRS_ResponseError 0x0 CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_ResponseError 0x0 CH4
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("3"); // 测试步骤 TC_Sleep 3
  g_EM_UDS_CAN_Swc_Diag("14 FF FF FF"); // 测试步骤 TC_CANTest Diag 14 FF FF FF
  g_EM_UDS_CAN_Swc_Diag("19 04 EF 2C 08 FF"); // 测试步骤 TC_CANTest Diag 19 04 EF 2C 08 FF
  g_EM_UDS_CAN_Swc_TC_CheckDiagRes("59 04 EF 2C 08 00"); // 预期结果 TC_CheckDiagRes 59 04 EF 2C 08 00
}

