testcase SYS_CDCU_xiangfen_0001()
{
  TestDescription("前置条件");
  teststep("warning","原始用例id为SYS-CDCU-香氛-0001");
  g_EM_Equipment_Swc_TC_PW("OFF"); // 测试步骤 TC_PW OFF
  g_EM_Equipment_Swc_TC_IG("OFF"); // 测试步骤 TC_IG OFF
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("2"); // 测试步骤 TC_Sleep 2
  g_EM_Equipment_Swc_TC_PW("ON"); // 测试步骤 TC_PW ON
  g_EM_Equipment_Swc_TC_IG("ON"); // 测试步骤 TC_IG ON
  gTC_CANTest_SOA_Set8001Delay("0"); // 测试步骤 TC_CANTest SOA Set8001Delay 0
  g_EM_SOAClient_Swc_SOA_StopSubPeriod(); // 测试步骤 TC_CANTest SOA StopSubPeriod//停止所有订阅
  g_CAN_Bus_Swc_AllCANDataDefaultAllCh(); // 测试步骤 TC_CANTest SET AllCANDataDefaultAllCh
  g_CAN_Bus_Swc_Disable_AllSentMessage(); // 测试步骤 TC_CANTest Disable AllSentMessage
  g_CAN_Bus_Swc_ClearCheckEvent(); // 测试步骤 TC_CANTest ClearCheckEvent
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
  g_EM_UDS_ETH_Swc_DOIP_Disconnect(); // 测试步骤 TC_CANTest DOIP Disconnect
  g_EM_SOAClient_Swc_SOA_SubPeriod("Veh_SFSService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod Veh_SFSService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("SOAEngineInterState 1"); // 测试步骤 TC_CANTest SOA SubPeriod SOAEngineInterState 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("SFSSt 1"); // 测试步骤 TC_CANTest SOA SubPeriod SFSSt 1
  g_EM_UDS_CAN_Swc_Diag("10 03"); // 测试步骤 TC_CANTest Diag 10 03
  g_EM_UDS_CAN_Swc_Diag_SA_01_02(); // 测试步骤 TC_CANTest Diag SA_01_02//一级解锁
  g_EM_UDS_CAN_Swc_Diag("2E CF 01 01 00 1E 00 0C 00 00 00 00 00"); // 测试步骤 TC_CANTest Diag 2E CF 01 01 00 1E 00 0C 00 00 00 00 00//配置香氛
  g_EM_UDS_CAN_Swc_TC_CheckDiagReply("6E CF 01"); // 预期结果 TC_CheckDiagReply 6E CF 01
  g_EM_UDS_CAN_Swc_Diag("2E CF 03 00 00 00 00 00 00 01 00 00 00 00 00 00 00 00 00 00 00 00 00"); // 测试步骤 TC_CANTest Diag 2E CF 03 00 00 00 00 00 00 01 00 00 00 00 00 00 00 00 00 00 00 00 00//配置lin香氛节点
  g_EM_UDS_CAN_Swc_TC_CheckDiagReply("6E CF 03"); // 预期结果 TC_CheckDiagReply 6E CF 03
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("1"); // 测试步骤 TC_Sleep 1
}

testcase SYS_CDCU_xiangfen_0003()
{
  TestDescription("初次上电默认浓度 Local on");
  teststep("warning","原始用例id为SYS-CDCU-香氛-0003");
  g_CAN_Bus_Swc_Set("I_LDCU_BodySysSt1.I_LDCU_PowerMode 1"); // 测试步骤 TC_CANTest SET I_LDCU_BodySysSt1.I_LDCU_PowerMode 1
  g_EM_SOAClient_Swc_SOA_REQ("Veh_SetSFSConStruct.Veh_SetSFSCon:1&ServiceExecuteFeedbackFlag:2&MemoryReq:1"); // 测试步骤 TC_CANTest SOA REQ Veh_SetSFSConStruct.Veh_SetSFSCon:1&ServiceExecuteFeedbackFlag:2&MemoryReq:1//low
  g_EM_Equipment_Swc_TC_4G_Time_Delay_Second("2"); // 测试步骤 TC_Sleep 2
  g_EM_LIN_Swc_LIN_Send("C4_FRS_CurrentIntensity 3 CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_CurrentIntensity 3 CH4//引擎转发香氛通道真实值-high
  g_EM_LIN_Swc_LIN_Send("C4_FRS_active_container 0x3 CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_active_container 0x3 CH4//引擎转发香氛通道真实值-ch3
  g_EM_LIN_Swc_LIN_Send("C4_FRS_FragranceID_Container_1 0x3F CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_FragranceID_Container_1 0x3F CH4//当前通道有效-ch3
  g_EM_LIN_Swc_LIN_Send("C4_FRS_FragranceID_Container_2 0x3F CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_FragranceID_Container_2 0x3F CH4//当前通道有效-ch3
  g_EM_LIN_Swc_LIN_Send("C4_FRS_FragranceID_Container_3 0x3F CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_FragranceID_Container_3 0x3F CH4//当前通道有效-ch3
  g_CAN_Bus_Swc_Set("C_LDCU_SysSt.C_LDCU_EVSysReadySt 2"); // 测试步骤 TC_CANTest SET C_LDCU_SysSt.C_LDCU_EVSysReadySt 2//上高压
  g_EM_LIN_Swc_LIN_Check("C4_FRS_IntensityReq 3 CH4"); // 预期结果 TC_LINTest LIN Check C4_FRS_IntensityReq 3 CH4
}

testcase SYS_CDCU_xiangfen_0004()
{
  TestDescription("香氛开启 Local on");
  teststep("warning","原始用例id为SYS-CDCU-香氛-0004");
  g_CAN_Bus_Swc_Set("I_LDCU_BodySysSt1.I_LDCU_PowerMode 1"); // 测试步骤 TC_CANTest SET I_LDCU_BodySysSt1.I_LDCU_PowerMode 1
  g_EM_LIN_Swc_LIN_Send("C4_FRS_CurrentIntensity 10 CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_CurrentIntensity 10 CH4//引擎转发香氛通道真实值-high
  g_EM_LIN_Swc_LIN_Send("C4_FRS_active_container 0x3 CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_active_container 0x3 CH4//引擎转发香氛通道真实值-ch3
  g_EM_LIN_Swc_LIN_Send("C4_FRS_FragranceID_Container_1 0x3F CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_FragranceID_Container_1 0x3F CH4//当前通道有效-ch3
  g_EM_LIN_Swc_LIN_Send("C4_FRS_FragranceID_Container_2 0x3F CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_FragranceID_Container_2 0x3F CH4//当前通道有效-ch3
  g_EM_LIN_Swc_LIN_Send("C4_FRS_FragranceID_Container_3 0x3F CH4"); // 测试步骤 TC_LINTest LIN Send C4_FRS_FragranceID_Container_3 0x3F CH4//当前通道有效-ch3
  g_CAN_Bus_Swc_Set("C_LDCU_SysSt.C_LDCU_EVSysReadySt 2"); // 测试步骤 TC_CANTest SET C_LDCU_SysSt.C_LDCU_EVSysReadySt 2//上高压
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_SetSFSChanelRespStruct.Veh_SetSFSChanelNRC 0"); // 预期结果 TC_CANTest SOA check Veh_SetSFSChanelRespStruct.Veh_SetSFSChanelNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_SFSService_ErrStruct.OpeNRC 0 traceback8"); // 预期结果 TC_CANTest SOA check Veh_SFSService_ErrStruct.OpeNRC 0 traceback8//
  g_EM_SOAClient_Swc_SOA_REQ("Veh_SetSFSChanelStruct.Veh_SetSFSChanel:3&ServiceExecuteFeedbackFlag:2&MemoryReq:1"); // 测试步骤 TC_CANTest SOA REQ Veh_SetSFSChanelStruct.Veh_SetSFSChanel:3&ServiceExecuteFeedbackFlag:2&MemoryReq:1//ON
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_SetSFSChanelRespStruct.Veh_SetSFSChanelNRC 0"); // 预期结果 TC_CANTest SOA check Veh_SetSFSChanelRespStruct.Veh_SetSFSChanelNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_SFSService_ErrStruct.OpeNRC 0 traceback8"); // 预期结果 TC_CANTest SOA check Veh_SFSService_ErrStruct.OpeNRC 0 traceback8//
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_SetSFSConRespStruct.Veh_SetSFSConNRC 0"); // 预期结果 TC_CANTest SOA check Veh_SetSFSConRespStruct.Veh_SetSFSConNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_SFSService_ErrStruct.OpeNRC 0 traceback8"); // 预期结果 TC_CANTest SOA check Veh_SFSService_ErrStruct.OpeNRC 0 traceback8//
  g_EM_SOAClient_Swc_SOA_REQ("Veh_SetSFSConStruct.Veh_SetSFSCon:2&ServiceExecuteFeedbackFlag:2&MemoryReq:1"); // 测试步骤 TC_CANTest SOA REQ Veh_SetSFSConStruct.Veh_SetSFSCon:2&ServiceExecuteFeedbackFlag:2&MemoryReq:1//High
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_SetSFSConRespStruct.Veh_SetSFSConNRC 0"); // 预期结果 TC_CANTest SOA check Veh_SetSFSConRespStruct.Veh_SetSFSConNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_SFSService_ErrStruct.OpeNRC 0 traceback8"); // 预期结果 TC_CANTest SOA check Veh_SFSService_ErrStruct.OpeNRC 0 traceback8//
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_TurnOnOffSFSRespStruct.Veh_TurnOnOffSFSNRC 0"); // 预期结果 TC_CANTest SOA check Veh_TurnOnOffSFSRespStruct.Veh_TurnOnOffSFSNRC 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("Veh_SFSService_ErrStruct.OpeNRC 0 traceback5"); // 预期结果 TC_CANTest SOA check Veh_SFSService_ErrStruct.OpeNRC 0 traceback5//
  g_EM_SOAClient_Swc_SOA_REQ("Veh_TurnOnOffSFSStruct.Veh_TurnOnOffSFS:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ Veh_TurnOnOffSFSStruct.Veh_TurnOnOffSFS:1&ServiceExecuteFeedbackFlag:2//ON
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_TurnOnOffSFSRespStruct.Veh_TurnOnOffSFSNRC 0"); // 预期结果 TC_CANTest SOA check Veh_TurnOnOffSFSRespStruct.Veh_TurnOnOffSFSNRC 0
  g_EM_LIN_Swc_LIN_Check("C4_FRS_IntensityReq 10 CH4"); // 预期结果 TC_LINTest LIN Check C4_FRS_IntensityReq 10 CH4
  g_EM_LIN_Swc_LIN_Check("C4_FRS_ChannelSelect 3 CH4"); // 预期结果 TC_LINTest LIN Check C4_FRS_ChannelSelect 3 CH4
  g_EM_SOAClient_Swc_SOA_CHECK("Veh_SFSService_ErrStruct.OpeNRC 0 traceback5"); // 预期结果 TC_CANTest SOA check Veh_SFSService_ErrStruct.OpeNRC 0 traceback5//
}

