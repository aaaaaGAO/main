testcase SYS_LDCU_DomeLight_055()
{
  TestDescription("左前顶灯控制点亮&熄灭");
  // Step Set_CF08 DomeLightDrvType 1//0x1 域控直驱 byte12 // 测试步骤Set_CF08关键字不存在
  teststep("step","Step Set_CF08 DomeLightDrvType 1//0x1 域控直驱 byte12");
  teststepfail("fail","Set_CF08关键字不存在");
  g_HIL_Bus_Swc_Set("VTS::VT2516_2_Ch13::DigitalOutput 10"); // 测试步骤 Step Set J_DI_FLTopLightSw_LS 10
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("VTS::VT2516_2_Ch13::DigitalOutput 0"); // 测试步骤 Step Set J_DI_FLTopLightSw_LS 0
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("VTS::VT2516_2_Ch13::DigitalOutput 10"); // 测试步骤 Step Set J_DI_FLTopLightSw_LS 10
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_FLDomeLightSwSt 1"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_FLDomeLightSwSt 1//0x1 Pressed
  g_HIL_Bus_Swc_Check("VTS::VT2516_5_Ch5::CurBit 0"); // 预期结果 Step Check J_DO_LS_FLTopLight 0//Active
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_FLDomeLightOutput 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_FLDomeLightOutput 2//0x2 On
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Set("VTS::VT2516_2_Ch13::DigitalOutput 0"); // 测试步骤 Step Set J_DI_FLTopLightSw_LS 0
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("VTS::VT2516_2_Ch13::DigitalOutput 10"); // 测试步骤 Step Set J_DI_FLTopLightSw_LS 10
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_FLDomeLightSwSt 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_FLDomeLightSwSt 0//0x0 Not Pressed
  g_HIL_Bus_Swc_Check("VTS::VT2516_5_Ch5::CurBit 1"); // 预期结果 Step Check J_DO_LS_FLTopLight 1//Inactive
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_FLDomeLightOutput 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_FLDomeLightOutput 0//0x0 OFF
}

