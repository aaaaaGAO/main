testcase SYS_RDCU_light_001()
{
  TestDescription("初始化车型配置-1");
  // Step Set_Config abcdfe 1322 // 测试步骤Configuration 解析失败: Name 未找到: abcdfe
  teststep("step","Step Set_Config abcdfe 1322");
  teststepfail("fail","Configuration 解析失败: Name 未找到: abcdfe");
  // Step Set_Config hhhhh 1322 // 测试步骤Configuration 解析失败: Name 未找到: hhhhh
  teststep("step","Step Set_Config hhhhh 1322");
  teststepfail("fail","Configuration 解析失败: Name 未找到: hhhhh");
  g_HIL_UDS_Swc_Set_Config("DomeLightModeSetSource 0"); // 测试步骤 Step Set_Config DomeLightModeSetSource 0//0x0LIN节点触发  0x1 CDCU屏控触发
  g_HIL_UDS_Swc_Set_Config("HandleTypeConfig 1"); // 测试步骤 Step Set_Config HandleTypeConfig 1//0x0 Electric Handle 电动门把手 0x1机械门把手
  g_HIL_Bus_Swc_Check("VTS::VT2516_2_Ch3::DigitalOutput 1"); // 测试步骤 Step Check J_PI_LeftLeverHALLFb1  1
}

testcase SYS_RDCU_light_001_1()
{
  TestDescription("LINdA信号赋值");
  teststep("warning","原始用例id为SYS-RDCU-light-001");
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
  g_HIL_Bus_Swc_Check("VTS::VT2516_2_Ch1::DigitalOutput"); // 预期结果 Step Check J_PI_RightLeverHALLFb1
  g_HIL_Gen_Swc_Wait("1000 ms"); // 测试步骤 Step Wait 1000 ms
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Dimmzeit 10"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Dimmzeit 10
  // Step Check J_PI_LeftLeverHALLFb1  open // 测试步骤io_mapping 解析失败: Values 为空: Name=J_PI_LeftLeverHALLFb1, Value=open
  teststep("step","Step Check J_PI_LeftLeverHALLFb1  open");
  teststepfail("fail","io_mapping 解析失败: Values 为空: Name=J_PI_LeftLeverHALLFb1, Value=open");
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zeitbasis 0"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zeitbasis 0
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Klemme_30G_aktiv eingeschaltet"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Klemme_30G_aktiv eingeschaltet
  // Step Check J_ECANH open // 测试步骤io_mapping 解析失败: Name 未找到: J_ECANH
  teststep("step","Step Check J_ECANH open");
  teststepfail("fail","io_mapping 解析失败: Name 未找到: J_ECANH");
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_Klemme_15 1"); // 预期结果 Step Check L5_LINDae_01::L5_Klemme_15 1//1 EIN 0 AUS
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
  g_HIL_Bus_Swc_Check("abc 1"); // 预期结果 Step Check abc 1
  g_HIL_Gen_Swc_Wait("100 ms"); // 测试步骤 Step Wait 100 ms
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_Klemme_15 0"); // 预期结果 Step Check L5_LINDae_01::L5_Klemme_15 0
  // Step abc 1 // 测试步骤abc关键字不存在
  teststep("step","Step abc 1");
  teststepfail("fail","abc关键字不存在");
  // Step Check J_ECANL 1 // 预期结果io_mapping 解析失败: Name 未找到: J_ECANL
  teststep("step","Step Check J_ECANL 1");
  teststepfail("fail","io_mapping 解析失败: Name 未找到: J_ECANL");
}

