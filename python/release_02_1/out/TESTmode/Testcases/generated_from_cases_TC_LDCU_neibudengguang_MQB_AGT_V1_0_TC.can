  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0 // 0 Dome 1 ON 2 OFF
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightState 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightState 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_REQ("FLDomeLightCtrlStruct.FLDomeLightCmd:1&ServiceExecuteFeedbackFlag:2"); // 测试步骤 TC_CANTest SOA REQ FLDomeLightCtrlStruct.FLDomeLightCmd:1&ServiceExecuteFeedbackFlag:2 //0x0:no command 0x1:ON 0x2:OFF
  g_HIL_Gen_Swc_Wait("1000 ms"); // 测试步骤 Step Wait 1000 ms
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 100"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 100
  gTC_CANTest_SOA_StopSomeipPeriod(); // 测试步骤 TC_CANTest SOA StopSomeipPeriod
  g_HIL_Clib_Swc_Clib_INTLGT_Gear_D(); // 测试步骤 Step Clib INTLGT_Gear_D//  D GearLev
  g_HIL_Gen_Swc_Wait("300 ms"); // 测试步骤 Step Wait 300 ms
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0
  g_HIL_Clib_Swc_Clib_INTLGT_Gear_P(); // 测试步骤 Step Clib INTLGT_Gear_P //P档
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0
}

testcase SYS_LDCU_DomeLight_044()
{
  TestDescription("顶灯跟随闭锁熄灭");
  g_HIL_Clib_Swc_Clib_AllDoorClosed(); // 测试步骤 Step Clib AllDoorClosed
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_DriverDoorAjarSt 0"); // 预期结果 Step Check  I_LDCU_BodySysSt1::I_LDCU_DriverDoorAjarSt 0 //0 close
