  g_HIL_Clib_Swc_Clib_AllDoorClosed(); // 测试步骤 Step Clib AllDoorClosed
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Set("I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 3"); // 测试步骤 Step Set I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 3//0x3:BLE Door lock
  g_HIL_Gen_Swc_Wait("201 ms"); // 测试步骤 Step Wait 201 ms
  g_HIL_Bus_Swc_Set("I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 4"); // 测试步骤 Step Set I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 4//0x4 BLE Door unlock
  g_HIL_Bus_Swc_Check("VTS::VT2516_5_Ch4::PWMDC 0"); // 预期结果 Step Check J_PO_LS_LDoorHandleLight_Duty level10//最亮
  g_HIL_Bus_Swc_Set("VTS::VT2848_3_Ch34::DigitalOutput 1"); // 测试步骤 Step Set J_DI_FLDoorAjarSW_LS 0//0x0 open
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_DriverDoorAjarSt 1 1 s"); // 预期结果 Step Check I_LDCU_BodySysSt1::I_LDCU_DriverDoorAjarSt 1 1 s//0x1 open
  g_HIL_Gen_Swc_Wait("180 s"); // 测试步骤 Step Wait 180 s
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 1"); // 测试步骤 Step Set I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 1//0x1 open
  g_HIL_Gen_Swc_Wait("420 s"); // 测试步骤 Step Wait 420 s
  g_HIL_Bus_Swc_Check("VTS::VT2516_5_Ch4::PWMDC 0"); // 预期结果 Step Check J_PO_LS_LDoorHandleLight_Duty Level10 //最亮
  g_HIL_Gen_Swc_Wait("180 s"); // 测试步骤 Step Wait 180 s
  g_HIL_Gen_Swc_Wait("301 ms"); // 测试步骤 Step Wait 301 ms
  g_HIL_Bus_Swc_Check("VTS::VT2516_5_Ch4::PWMDC > 0.95"); // 预期结果 Step Check J_PO_LS_LDoorHandleLight_Duty OFF //
}

