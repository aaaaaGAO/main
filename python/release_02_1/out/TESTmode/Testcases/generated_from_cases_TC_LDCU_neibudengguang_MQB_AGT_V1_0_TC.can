  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_RLDoorAjarSt 0"); // 预期结果 Step Check  I_LDCU_BodySysSt1::I_LDCU_RLDoorAjarSt 0 //0 close
  g_HIL_Bus_Swc_Check("I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0"); // 预期结果 Step Check I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0// 0 close
