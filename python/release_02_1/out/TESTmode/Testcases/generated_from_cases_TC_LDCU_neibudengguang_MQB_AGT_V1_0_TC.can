  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 100"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 100
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Dimmzeit 10"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Dimmzeit 10
  g_HIL_Bus_Swc_Set("L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 1"); // 测试步骤 Step Set L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 1 //   0:Taste_unbetaetigt    1:Taste_betaetigt
  g_HIL_Gen_Swc_Wait("1000 ms"); // 测试步骤 Step Wait 1000 ms
  g_HIL_Bus_Swc_Set("L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 0"); // 测试步骤 Step Set L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 0 //   0:Taste_unbetaetigt    1:Taste_betaetigt
  g_HIL_Gen_Swc_Wait("300 ms"); // 测试步骤 Step Wait 300 ms   //关闭DOME模式
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2 // 0 Dome 1 ON 2 OFF
  g_HIL_Bus_Swc_Set("VTS::VT2516_1_Ch4::DigitalOutput 1"); // 测试步骤 Step Set J_AI_DrvSeatSBRSt Unoccupied
  g_HIL_Bus_Swc_Set("I_CDCU_AssistSysSwSt::I_DrvSeatOccupancySt 0"); // 测试步骤 Step Set I_CDCU_AssistSysSwSt::I_DrvSeatOccupancySt 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_DrvSeatOccupancySt 0"); // 预期结果 Step Check  I_LDCU_BodySysSt1::I_LDCU_DrvSeatOccupancySt 0 //未占座
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0"); // 测试步骤 Step Set I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0//0 close
  g_HIL_Bus_Swc_Set("I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 0"); // 测试步骤 Step Set I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 0
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_LockLogicSt 0"); // 预期结果 Step Check  I_LDCU_BodySysSt1::I_LDCU_LockLogicSt 0 //0 unlock
  g_HIL_Bus_Swc_Set("I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 3"); // 测试步骤 Step Set I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 3//0x3:BLE Door lock
  g_HIL_Gen_Swc_Wait("200 ms"); // 测试步骤 Step Wait 200 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_LockLogicSt 1"); // 预期结果 Step Check  I_LDCU_BodySysSt1::I_LDCU_LockLogicSt 1 //1 lock
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0 2 s"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0 2 s// 之前出现过闭锁后1.6S发生亮灯
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0 2 s"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 0 2 s// 之前出现过闭锁后1.6S发生亮灯
  g_HIL_Bus_Swc_Set("I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 4"); // 测试步骤 Step Set I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 4// Unlock
  g_HIL_Bus_Swc_Set("I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 0"); // 测试步骤 Step Set I_TBOX_WinRemoteCtrl::I_TBOX_LDCU_DoorLockReq 0
}

