  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt1::I_LDCU_DriverDoorAjarSt 0"); // 预期结果 Step Check  I_LDCU_BodySysSt1::I_LDCU_DriverDoorAjarSt 0 //0 close
