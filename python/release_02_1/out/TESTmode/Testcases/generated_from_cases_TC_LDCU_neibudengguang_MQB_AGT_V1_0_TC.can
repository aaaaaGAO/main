testcase SYS_LDCU_SWSlogoLight_011()
{
  TestDescription("方向盘Logo灯-Always on模式+ 熄灭（下电熄灭）");
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
  g_HIL_Bus_Swc_Set("I_CDCU_State::I_AmbientLightbrightness 0xA"); // 测试步骤 Step Set I_CDCU_State::I_AmbientLightbrightness 0xA//0xA 100%PWM 20%亮度
  g_HIL_Bus_Swc_Set("I_CDCU_State::I_AmbientLightSwSt 1"); // 测试步骤 Step Set I_CDCU_State::I_AmbientLightSwSt 1 //1:ON  默认OFF 0
  g_HIL_Bus_Swc_Check("VTS::VT2516_3_Ch9::Cur > 0.75 and < 0.85 1 s"); // 预期结果 Step Check J_PO_LS_SWSlogoLight_Duty Level8 1 s// 20%最亮
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
  g_HIL_Bus_Swc_Check("VTS::VT2516_3_Ch9::Cur > 0.95 1 s"); // 预期结果 Step Check J_PO_LS_SWSlogoLight_Duty Level10 1 s
  g_HIL_Gen_Swc_Wait("1 s"); // 测试步骤 Step Wait 1 s
  g_HIL_Bus_Swc_Check("VTS::VT2516_3_Ch9::Cur > 0.95 1 s"); // 预期结果 Step Check J_PO_LS_SWSlogoLight_Duty Level10 1 s
  g_HIL_Bus_Swc_Set("I_CDCU_State::I_AmbientLightSwSt 0"); // 测试步骤 Step Set I_CDCU_State::I_AmbientLightSwSt 0 //1:ON  默认OFF 0
  g_HIL_Bus_Swc_Set("I_CDCU_State::I_AmbientLightbrightness 0"); // 测试步骤 Step Set I_CDCU_State::I_AmbientLightbrightness 0//0x0 No Comment
}

