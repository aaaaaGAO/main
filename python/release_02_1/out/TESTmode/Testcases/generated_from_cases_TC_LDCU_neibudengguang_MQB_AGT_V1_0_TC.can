  g_HIL_Gen_Swc_Wait("300 ms"); // 测试步骤 Step Wait 300 ms
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Adressat 0x3F"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Adressat 0x3F
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 100"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Zielhelligkeit 100
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0"); // 测试步骤 Step Set I_RDCU_BodySysSt1::I_RDCU_PsngrDoorAjarSt 0//0 close
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_IL_Dachkonsole_Dimmzeit 10"); // 预期结果 Step Check L5_LINDae_01::L5_IL_Dachkonsole_Dimmzeit 10
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
}

testcase SYS_LDCU_DomeLight_006()
{
  TestDescription("Dome响应门信号顶灯点亮500ms内黑夜---LIN信号发布规则");
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
