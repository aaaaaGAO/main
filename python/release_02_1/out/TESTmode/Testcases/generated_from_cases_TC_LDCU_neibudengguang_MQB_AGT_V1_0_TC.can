  g_HIL_UDS_Swc_Set_Config("CF05Reserved01 1"); // 预期结果 Step  Set_config CF05Reserved01 1
}

testcase SYS_LDCU_DomeLight_001()
{
  TestDescription("LINDA顶灯模式设置- CDCU屏控触发");
  teststep("warning","原始用例id为SYS-LDCU-DomeLight -001");
  g_HIL_UDS_Swc_Set_Config("DomeLightDrvType 1"); // 测试步骤 Step Set_Config DomeLightDrvType 1//域控直驱
  // Step Set_config  abc 1 // 预期结果Configuration 解析失败: Name 未找到: abc
  teststep("step","Step Set_config  abc 1");
  teststepfail("fail","Configuration 解析失败: Name 未找到: abc");
  g_HIL_UDS_Swc_Set_Config("VehicleType 2"); // 测试步骤 Step Set_Config VehicleType 2//CMP21 06
  g_HIL_Bus_Swc_Check("abc 1"); // 预期结果 Step Check abc 1
  g_HIL_UDS_Swc_Set_Config("DomeLightModeSetSource 1"); // 测试步骤 Step Set_Config DomeLightModeSetSource 1//CDCU屏控触发
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 1"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 1 //0x0:No command,0x1:Dome,0x2:ON,0x3:OFF,
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 0"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 0 //0x0:No command,0x1:Dome,0x2:ON,0x3:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0 // 0 Dome 1 ON 2 OFF
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 3"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 3 //0x0:No command,0x1:Dome,0x2:ON,0x3:OFF,
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 0"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 0 //0x0:No command,0x1:Dome,0x2:ON,0x3:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2 // 0 Dome 1 ON 2 OFF
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 1"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 1 //0x0:No command,0x1:Dome,0x2:ON,0x3:OFF,
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_Bus_Swc_Set("I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 0"); // 测试步骤 Step Set I_CDCU_LDCU_BodyCtrl::I_CDCU_DomeLightMode 0 //0x0:No command,0x1:Dome,0x2:ON,0x3:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0 // 0 Dome 1 ON 2 OFF
  g_HIL_Gen_Swc_Wait("500 ms"); // 测试步骤 Step Wait 500 ms
  g_HIL_UDS_Swc_Set_Config("DomeLightDrvType 0"); // 测试步骤 Step Set_Config DomeLightDrvType 0//0x1域控直驱 0x0Lin节点驱动 CF08 Byte12
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
}

testcase SYS_LDCU_DomeLight_002()
{
  TestDescription("LINDA顶灯模式设置-Dome关闭");
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightState 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightState 1
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("SetDomeLightModeRespStruct.SetDomeLightModeNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check SetDomeLightModeRespStruct.SetDomeLightModeNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("InteriorLightState1Struct.DomeLightModeFb 0"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 0//0x0:Dome,0x1:ON,0x2:OFF,
  g_EM_SOAClient_Swc_SOA_REQ("SetDomeLightModeStruct.DomeLightModeCfg:1&ServiceExecuteFeedbackFlag:1"); // 测试步骤 TC_CANTest SOA REQ SetDomeLightModeStruct.DomeLightModeCfg:1&ServiceExecuteFeedbackFlag:1 //0x0:No Command 0x1:Dome 0x2:Dome off
  g_EM_SOAClient_Swc_SOA_CHECK("SetDomeLightModeRespStruct.SetDomeLightModeNRC 0&RespCode 0"); // 预期结果 TC_CANTest SOA check SetDomeLightModeRespStruct.SetDomeLightModeNRC 0&RespCode 0
  g_EM_SOAClient_Swc_SOA_CHECK("InteriorLightState1Struct.DomeLightModeFb 0"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 0//0x0:Dome,0x1:ON,0x2:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0 // 0 Dome 1 ON 2 OFF
  g_HIL_Bus_Swc_Check("L5_LINDae_01::L5_Tuerkontakt_Innenlicht_Status 1"); // 预期结果 Step Check L5_LINDae_01::L5_Tuerkontakt_Innenlicht_Status 1 //0:Tuerkontakt_nicht_gesetzt  1:Tuerkontakt_gesetzt
  g_HIL_Bus_Swc_Set("L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 1"); // 测试步骤 Step Set L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 1 //   0:Taste_unbetaetigt    1:Taste_betaetigt
  g_HIL_Gen_Swc_Wait("2000 ms"); // 测试步骤 Step Wait 2000 ms
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("InteriorLightState1Struct.DomeLightModeFb 2"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 2//0x0:Dome,0x1:ON,0x2:OFF,
  g_HIL_Bus_Swc_Set("L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 0"); // 测试步骤 Step Set L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 0 //   0:Taste_unbetaetigt    1:Taste_betaetigt
  g_EM_SOAClient_Swc_SOA_CHECK("InteriorLightState1Struct.DomeLightModeFb 2"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 2//0x0:Dome,0x1:ON,0x2:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2 // 0 Dome 1 ON 2 OFF
  g_HIL_Clib_Swc_Clib_Reset(); // 测试步骤 Step Clib Reset//确认复位后是否记忆
  g_HIL_Gen_Swc_Wait("300 ms"); // 测试步骤 Step Wait 300 ms
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("InteriorLightState1Struct.DomeLightModeFb 2"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 2//0x0:Dome,0x1:ON,0x2:OFF,
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightState 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightState 1
  g_EM_SOAClient_Swc_SOA_CHECK("InteriorLightState1Struct.DomeLightModeFb 2"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 2//0x0:Dome,0x1:ON,0x2:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2 // 0 Dome 1 ON 2 OFF
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
  gTC_CANTest_SOA_StopSomeipPeriod(); // 测试步骤 TC_CANTest SOA StopSomeipPeriod
}

testcase SYS_LDCU_DomeLight_003()
{
  TestDescription("LINDA顶灯模式设置-Dome开启(须先关闭)");
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightState 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightState 1
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("InteriorLightState1Struct.DomeLightModeFb 2"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 2//0x0:Dome,0x1:ON,0x2:OFF,
  g_EM_SOAClient_Swc_SOA_SubPeriod("InteriorLightService_ErrGrp 1"); // 测试步骤 TC_CANTest SOA SubPeriod InteriorLightService_ErrGrp 1
  g_EM_SOAClient_Swc_SOA_CHECK("InteriorLightState1Struct.DomeLightModeFb 2"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 2//0x0:Dome,0x1:ON,0x2:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2 // 0 Dome 1 ON 2 OFF
  g_HIL_Bus_Swc_Set("L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 1"); // 测试步骤 Step Set L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 1 //   0:Taste_unbetaetigt    1:Taste_betaetigt
  g_HIL_Gen_Swc_Wait("1000 ms"); // 测试步骤 Step Wait 1000 ms
  g_HIL_Bus_Swc_Set("L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 0"); // 测试步骤 Step Set L5_LINDas_01::L5_Tuerkontakt_Innenlicht_Taste 0 //   0:Taste_unbetaetigt    1:Taste_betaetigt
  g_HIL_Gen_Swc_Wait("300 ms"); // 测试步骤 Step Wait 300 ms
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0// 0 Dome 1 ON 2 OFF
  g_HIL_Clib_Swc_Clib_Reset(); // 测试步骤 Step Clib Reset//确认复位后是否记忆
  g_HIL_Gen_Swc_Wait("300 ms"); // 测试步骤 Step Wait 300 ms
  g_EM_SOAClient_Swc_SOA_CHECK_Prepare("InteriorLightState1Struct.DomeLightModeFb 0"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 0//0x0:Dome,0x1:ON,0x2:OFF,
  g_EM_SOAClient_Swc_SOA_CHECK("InteriorLightState1Struct.DomeLightModeFb 0"); // 预期结果 TC_CANTest SOA check InteriorLightState1Struct.DomeLightModeFb 0//0x0:Dome,0x1:ON,0x2:OFF,
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 0 // 0 Dome 1 ON 2 OFF
  g_HIL_Clib_Swc_Clib_OFF(); // 测试步骤 Step Clib OFF
  gTC_CANTest_SOA_StopSomeipPeriod(); // 测试步骤 TC_CANTest SOA StopSomeipPeriod
}

testcase SYS_LDCU_DomeLight_004()
{
  TestDescription("Dome关闭后开门不亮灯");
  g_HIL_Clib_Swc_Clib_BrkLocalON(); // 测试步骤 Step Clib BrkLocalON
  g_HIL_Bus_Swc_Check("I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2"); // 预期结果 Step Check I_LDCU_BodySysSt2::I_LDCU_DomeLightModeFb 2 // 0 Dome 1 ON 2 OFF
  g_HIL_Bus_Swc_Set("I_RDCU_BodySysSt2::I_RDCU_EnvrMode 2"); // 测试步骤 Step Set I_RDCU_BodySysSt2::I_RDCU_EnvrMode 2// NIGHT
